<div class="trust-timeline">
    <h2 class="fw-800 text-dark">Titan <span class="text-danger">Trust Ledger</span></h2>
    <p class="text-muted">Verified Blockchain Traceability for Unit: @ViewBag.ProductId</p>

    <div class="ledger-container">
        @foreach (var block in Model) {
            <div class="ledger-item border-start border-danger ps-4 pb-4 position-relative">
                <div class="hash-dot bg-danger"></div>
                <div class="d-flex justify-content-between">
                    <span class="fw-800 text-uppercase">@block.Data</span>
                    <small class="font-monospace text-muted">#@block.Hash.Substring(0, 12)</small>
                </div>
                <div class="text-muted small">Verified at Roorkee Node: @block.Timestamp</div>
                
                <div class="badge bg-success bg-opacity-10 text-success border border-success mt-2">
                    <i class="fas fa-check-double me-1"></i> CRYPTO_VERIFIED
                </div>
            </div>
        }
    </div>
</div>