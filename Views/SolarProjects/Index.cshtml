@model IEnumerable<EaproERP.Models.SolarProject>
@{
    ViewData["Title"] = "Solar Command Center";
}

<style>
    /* --- Solar Project Premium Styling --- */
    .project-container {
        animation: fadeInUp 0.7s ease-out;
    }

    .glass-project-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 30px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
    }

    .glass-project-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
        border-color: var(--eapro-red);
    }

    /* Status Indicator Glow */
    .status-badge {
        font-size: 0.7rem;
        font-weight: 800;
        padding: 6px 14px;
        border-radius: 100px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .status-commissioned { background: rgba(16, 185, 129, 0.1); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.2); }
    .status-installation { background: rgba(59, 130, 246, 0.1); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.2); }
    .status-survey { background: rgba(245, 158, 11, 0.1); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.2); }

    /* Neon Progress Bar */
    .progress-track {
        height: 8px;
        background: #F1F5F9;
        border-radius: 20px;
        overflow: hidden;
        margin: 20px 0;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #D32F2F 0%, #FF5252 100%);
        box-shadow: 0 0 15px rgba(211, 47, 47, 0.4);
        border-radius: 20px;
        transition: width 1s ease-in-out;
    }

    /* Metric Box */
    .metric-square {
        background: #F8FAFC;
        border-radius: 20px;
        padding: 15px;
        border: 1px solid #EDF2F7;
        text-align: center;
    }

    .btn-circle-action {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #fff;
        border: 1px solid #E2E8F0;
        color: #64748B;
        transition: 0.3s;
    }

    .btn-circle-action:hover {
        background: var(--eapro-dark);
        color: #fff;
        transform: rotate(15deg);
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="project-container">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h1 class="fw-800 text-dark mb-1" style="letter-spacing: -1.5px;">Solar Command Center</h1>
            <p class="text-muted mb-0"><i class="fas fa-satellite text-danger me-2"></i>Real-time Deployment Tracking: India Network</p>
        </div>
        <div class="d-flex gap-3">
             <div class="bg-white px-4 py-2 rounded-pill shadow-sm border d-flex align-items-center">
                <span class="fw-800 text-danger me-2">@Model.Count()</span>
                <small class="text-muted fw-bold uppercase">Active Sites</small>
            </div>
            <a asp-action="Create" class="btn btn-danger rounded-pill px-4 py-2 shadow-lg fw-bold border-0">
                <i class="fas fa-plus-circle me-2"></i>New Installation
            </a>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model) {
            <div class="col-xl-6">
                <div class="glass-project-card p-4 h-100 shadow-sm">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-dark text-white rounded-4 d-flex align-items-center justify-content-center me-3" style="width: 54px; height: 54px;">
                                <i class="fas @(item.ProjectType.Contains("On-Grid") ? "fa-plug-circle-bolt" : "fa-battery-full") fs-4"></i>
                            </div>
                            <div>
                                <h5 class="fw-800 mb-0">@item.ClientName</h5>
                                <small class="text-muted"><i class="fas fa-location-dot me-1"></i> @item.Location</small>
                            </div>
                        </div>
                        <span class="status-badge @(item.Status == "Commissioned" ? "status-commissioned" : item.Status == "Installation" ? "status-installation" : "status-survey")">
                            @item.Status
                        </span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-4">
                            <div class="metric-square">
                                <small class="text-muted d-block mb-1">Capacity</small>
                                <span class="fw-800 text-dark">@item.CapacityKW <span class="small">kWp</span></span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="metric-square">
                                <small class="text-muted d-block mb-1">Contract</small>
                                <span class="fw-800 text-danger">₹@(item.ContractValue >= 100000 ? (item.ContractValue / 100000).ToString("N1") + "L" : item.ContractValue.ToString("N0"))</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="metric-square">
                                <small class="text-muted d-block mb-1">Type</small>
                                <span class="fw-bold text-dark small">@item.ProjectType</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4 px-1">
                        <div class="d-flex justify-content-between small fw-bold mb-2">
                            <span class="text-muted">Deployment Progress</span>
                            <span class="text-danger">@(item.Status == "Commissioned" ? "100%" : item.Status == "Installation" ? "65%" : "15%")</span>
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width: @(item.Status == "Commissioned" ? "100%" : item.Status == "Installation" ? "65%" : "15%")"></div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm">
                            <i class="fas fa-chart-line me-2"></i>Full Logistics
                        </a>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-circle-action" title="Edit Site Data"><i class="fas fa-sliders"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-circle-action text-danger" title="Terminate Project"><i class="fas fa-trash-can"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>