@model EaproERP.Models.SolarProject
@{ ViewData["Title"] = "Project Milestone Tracker"; }

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-dark p-4 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        <div class="bg-danger rounded-circle p-3 me-3">
                            <i class="fas fa-satellite text-white fs-4"></i>
                        </div>
                        <div>
                            <h4 class="text-white mb-0 fw-bold">@Model.ClientName</h4>
                            <small class="text-white-50">Project ID: #PRJ-@Model.Id</small>
                        </div>
                    </div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-light rounded-pill px-4">Update Status</a>
                </div>

                <div class="card-body p-5">
                    <div class="mb-5 text-center">
                        <h6 class="text-uppercase text-muted fw-bold mb-4">Installation Progress</h6>
                        <div class="position-relative mb-4">
                            <div class="progress" style="height: 12px; background: #e9ecef; border-radius: 10px;">
                                <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" 
                                     style="width: @(Model.Status == "Commissioned" ? "100%" : Model.Status == "Installation" ? "65%" : "25%")">
                                </div>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between text-muted small px-2">
                            <span class="@(Model.Status == "Survey Pending" ? "text-danger fw-bold" : "")">Survey</span>
                            <span class="@(Model.Status == "Installation" ? "text-danger fw-bold" : "")">Installation</span>
                            <span class="@(Model.Status == "Commissioned" ? "text-danger fw-bold" : "")">Live</span>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="p-3 border rounded-3 bg-light">
                                <small class="text-muted d-block">System Type</small>
                                <span class="fw-bold">@Model.ProjectType</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded-3 bg-light">
                                <small class="text-muted d-block">Capacity</small>
                                <span class="fw-bold">@Model.CapacityKW kWp</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3 border rounded-3 bg-light">
                                <small class="text-muted d-block">Location</small>
                                <span class="fw-bold">@Model.Location</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, #0F111A 0%, #2c3e50 100%);">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h5 class="text-white fw-bold mb-1">Contract Value</h5>
                                <p class="text-white-50 mb-0">Total project investment for EAPRO Solar Solution.</p>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <h3 class="text-danger fw-bold mb-0">₹@Model.ContractValue.ToString("N0")</h3>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light p-3 text-center">
                    <a asp-action="Index" class="btn btn-link text-decoration-none text-muted">Back to Project List</a>
                </div>
            </div>
        </div>
    </div>
</div>