@model EaproERP.Models.SolarProject
@{ ViewData["Title"] = "Project Engineering"; }

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --input-bg: #F8FAFC;
        --solar-gold: #F59E0B;
    }

    .project-container { animation: slideInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Technical Blueprint Header */
    .blueprint-header {
        background: linear-gradient(135deg, var(--eapro-slate) 0%, #0F172A 100%);
        border-radius: 30px;
        padding: 3rem;
        color: white;
        margin-bottom: -50px;
        position: relative;
        z-index: 2;
        border-left: 8px solid var(--eapro-red);
        box-shadow: 0 25px 50px rgba(0,0,0,0.2);
    }

    /* Main Config Card */
    .config-card {
        background: white;
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
        padding: 6rem 4rem 4rem 4rem;
    }

    .form-section-label {
        display: flex;
        align-items: center;
        gap: 15px;
        margin: 2.5rem 0 1.5rem 0;
    }
    .form-section-label span {
        font-size: 0.75rem;
        font-weight: 800;
        color: #94A3B8;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .section-line { height: 1px; background: #f1f5f9; width: 100%; }

    .input-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 10px;
        display: block;
    }

    .form-control, .form-select {
        border-radius: 18px;
        background: var(--input-bg);
        border: 1px solid #E2E8F0;
        padding: 16px 20px;
        font-weight: 600;
        color: var(--eapro-slate);
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .form-control:focus {
        background: white;
        border-color: var(--eapro-red);
        box-shadow: 0 10px 25px rgba(211, 47, 47, 0.1);
        transform: translateY(-2px);
    }

    /* System Stats Badge */
    .tech-badge {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 10px 20px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-save-project {
        background: var(--eapro-red);
        color: white;
        border: none;
        border-radius: 100px;
        padding: 20px 50px;
        font-weight: 800;
        letter-spacing: 1px;
        box-shadow: 0 15px 35px rgba(211, 47, 47, 0.3);
        transition: 0.4s;
    }

    .btn-save-project:hover {
        background: #B91C1C;
        transform: scale(1.03) translateY(-3px);
        box-shadow: 0 20px 45px rgba(211, 47, 47, 0.4);
    }

    .currency-symbol {
        font-weight: 800;
        color: #10B981;
        font-size: 1.2rem;
    }

    @@keyframes slideInUp { from { opacity: 0; transform: translateY(50px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container project-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="blueprint-header">
                <div class="row align-items-center">
                    <div class="col">
                        <span class="badge bg-danger bg-opacity-25 text-danger px-3 py-2 rounded-pill fw-800 mb-3">SYSTEM CONFIGURATION MODE</span>
                        <h1 class="fw-800 mb-2">@(Model?.Id > 0 ? "Edit Project Blueprint" : "Initialize New Solar Project")</h1>
                        <div class="d-flex gap-4 mt-3">
                            <div class="tech-badge">
                                <i class="fas fa-microchip text-danger"></i>
                                <span class="small fw-bold">CORE V2.5</span>
                            </div>
                            <div class="tech-badge">
                                <i class="fas fa-location-crosshairs text-info"></i>
                                <span class="small fw-bold">GEOSPATIAL LINK READY</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <i class="fas fa-solar-panel text-white opacity-25" style="font-size: 8rem;"></i>
                    </div>
                </div>
            </div>

            <div class="config-card">
                <form asp-action="@ViewContext.RouteData.Values["action"]">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4 mb-4"></div>
                    @if(Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }

                    <div class="form-section-label">
                        <span><i class="fas fa-user-tie me-2"></i>Deployment Context</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            <label class="input-label">Entity / Client Name</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent text-muted"><i class="fas fa-building"></i></span>
                                <input asp-for="ClientName" class="form-control ms-n3" placeholder="e.g. Roorkee Railway Station" required />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <label class="input-label">Geographic Location</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent text-muted"><i class="fas fa-map-location-dot"></i></span>
                                <input asp-for="Location" class="form-control ms-n3" placeholder="City, State" required />
                            </div>
                        </div>
                    </div>

                    <div class="form-section-label">
                        <span><i class="fas fa-bolt me-2"></i>Engineering Specifications</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="input-label">Solution Architecture</label>
                            <select asp-for="ProjectType" class="form-select">
                                <option value="On-Grid">On-Grid (Net Metering)</option>
                                <option value="Off-Grid">Off-Grid (Storage)</option>
                                <option value="Hybrid">Hybrid (Intelligent)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Peak Capacity (kWp)</label>
                            <div class="input-group">
                                <input asp-for="CapacityKW" class="form-control fw-800 text-danger" placeholder="0.00" />
                                <span class="input-group-text border-0 bg-light fw-bold text-muted">kWp</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Operational Status</label>
                            <select asp-for="Status" class="form-select fw-bold">
                                <option value="Survey Pending">Pre-Installation Survey</option>
                                <option value="Installation">Active Deployment</option>
                                <option value="Commissioned">Live / Grid-Tied</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-section-label">
                        <span><i class="fas fa-file-invoice-dollar me-2"></i>Commercial Valuation</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row mb-5">
                        <div class="col-md-6">
                            <label class="input-label">Total Contract Value (₹)</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent currency-symbol">₹</span>
                                <input asp-for="ContractValue" class="form-control ms-n3 fs-4 fw-800 text-dark" placeholder="0.00" />
                            </div>
                            <small class="text-muted">Total value including BOS and installation charges.</small>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-top d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="text-decoration-none text-muted fw-800 small uppercase"><i class="fas fa-arrow-left me-2"></i>Back to Projects</a>
                        <button type="submit" class="btn-save-project">
                            PUBLISH PROJECT RECORD <i class="fas fa-cloud-upload-alt ms-2"></i>
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>