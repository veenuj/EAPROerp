@model IEnumerable<EaproERP.Models.CustomerTicket>
@{ 
    ViewData["Title"] = "Service Desk Dashboard"; 
}

<style>
    :root {
        --titan-red: #D32F2F;
        --titan-dark: #0F172A;
        --titan-border: #E2E8F0;
        --titan-bg: #F8FAFC;
    }

    /* --- DASHBOARD STYLES --- */
    .admin-card { 
        background: #fff; border: 1px solid var(--titan-border); border-radius: 24px; padding: 35px; box-shadow: 0 15px 40px rgba(0,0,0,0.04); animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1); position: relative; overflow: hidden;
    }
    .admin-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: linear-gradient(90deg, var(--titan-red), #ff7043);
    }
    .table-custom th { font-size: 0.7rem; text-transform: uppercase; font-weight: 800; color: #94A3B8; letter-spacing: 1.2px; border-bottom: 2px solid var(--titan-border); padding-bottom: 15px; }
    .table-custom td { vertical-align: middle; font-weight: 600; color: var(--titan-dark); border-bottom: 1px solid #F1F5F9; padding: 18px 10px; transition: background 0.2s ease; }
    .table-hover tbody tr:hover td { background-color: var(--titan-bg); }
    .status-badge { font-size: 0.75rem; letter-spacing: 0.5px; }
    .btn-action { transition: 0.3s transform, 0.3s box-shadow; }
    .btn-action:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div id="secure-dashboard">
    <div class="py-4">
        
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-danger d-inline-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 55px; height: 55px;">
                    <i class="fas fa-server text-white fs-4"></i>
                </div>
                <div>
                    <h2 class="fw-900 text-dark mb-0" style="letter-spacing: -1px;">Service <span class="text-danger">Desk</span></h2>
                    <p class="text-muted fw-bold small uppercase mb-0 font-monospace"><i class="fas fa-satellite-dish me-2 text-success"></i>Live Customer Inquiries</p>
                </div>
            </div>
            
            <div class="d-flex align-items-center gap-2">
                <div class="badge bg-dark rounded-pill px-4 py-3 font-monospace shadow-sm" style="font-size: 0.85rem;">
                    @Model.Count(t => t.Status == "Open") OPEN TICKETS
                </div>
            </div>
        </div>

        <div class="admin-card table-responsive">
            <table class="table table-borderless table-custom table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Ticket ID</th>
                        <th>Date Received</th>
                        <th>Customer Info</th>
                        <th>Service Type</th>
                        <th>Product S/N</th>
                        <th>Details</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in Model)
                    {
                        <tr>
                            <td class="font-monospace fw-bold" style="color: var(--titan-red);">#@ticket.Id.ToString("D4")</td>
                            <td>
                                <div class="fw-bold text-dark">@ticket.CreatedAt.ToString("dd MMM yyyy")</div>
                                <div class="small text-muted font-monospace">@ticket.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark mb-1">@ticket.CustomerName</div>
                                <div class="small fw-bold text-muted"><i class="fas fa-phone text-danger me-1"></i> @ticket.PhoneNumber</div>
                            </td>
                            <td>
                                <span class="badge bg-light border text-dark px-3 py-2 rounded-pill fw-bold">@ticket.RequestType</span>
                            </td>
                            <td class="font-monospace text-muted fw-bold">@ticket.ProductSerialNumber</td>
                            <td>
                                <button class="btn btn-sm btn-light border rounded-pill px-3 fw-bold text-muted btn-action" onclick="viewDetails('@ticket.Id.ToString("D4")', '@ticket.RequestType', '@ticket.Description.Replace("'", "\\'")')">
                                    <i class="fas fa-eye me-1"></i> Read
                                </button>
                            </td>
                            <td>
                                @if(ticket.Status == "Open") { 
                                    <span class="badge bg-warning-subtle text-warning border border-warning px-3 py-2 rounded-pill status-badge fw-bold"><i class="fas fa-clock me-1"></i> OPEN</span> 
                                }
                                else { 
                                    <span class="badge bg-success-subtle text-success border border-success px-3 py-2 rounded-pill status-badge fw-bold"><i class="fas fa-check-double me-1"></i> RESOLVED</span> 
                                }
                            </td>
                            <td class="text-end">
                                @if(ticket.Status == "Open")
                                {
                                    <form asp-action="ResolveTicket" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@ticket.Id" />
                                        <button type="submit" class="btn btn-sm btn-dark rounded-pill fw-bold px-4 py-2 shadow-sm btn-action">
                                            Mark Resolved
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-light rounded-pill fw-bold px-4 py-2 disabled border-0" style="opacity: 0.5;">
                                        Closed
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            @if(!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox text-muted mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
                    <h5 class="fw-bold text-dark mb-0">No Tickets Found</h5>
                    <p class="text-muted small">Your service desk is currently empty.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            checkTempData();
        });

        // Handle TempData for Success Messages
        function checkTempData() {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                setTimeout(() => {
                    Swal.fire({
                        title: 'System Update',
                        text: '@TempData["SuccessMessage"]',
                        icon: 'success',
                        confirmButtonColor: '#0F172A',
                        customClass: { popup: 'rounded-4 shadow-lg border', confirmButton: 'rounded-pill px-4 fw-bold' }
                    });
                }, 100); 
                </text>
            }
        }

        // View Details Modal
        function viewDetails(ticketId, type, description) {
            Swal.fire({
                title: `<div class="fs-5 text-muted mb-1">Ticket #${ticketId}</div><div class="fw-900 text-dark">${type}</div>`,
                html: `<div class="text-start mt-3 p-4 bg-light rounded-4 border"><p class="mb-0 text-dark fw-bold" style="line-height: 1.6;">${description}</p></div>`,
                confirmButtonColor: '#D32F2F',
                confirmButtonText: 'Close',
                customClass: { popup: 'rounded-4 shadow-lg border', confirmButton: 'rounded-pill px-5 fw-bold' }
            });
        }
    </script>
}