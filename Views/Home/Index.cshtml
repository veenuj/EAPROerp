@{
    ViewData["Title"] = "EAPRO ERP | Command Center";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-red-glow: rgba(211, 47, 47, 0.4);
        --eapro-red-light: #ff4d4d;
        --dark-bg: #030508;
        --glass-bg: rgba(20, 25, 35, 0.4);
        --glass-border: rgba(255, 255, 255, 0.06);
        --text-muted: #8B9BB4;
        --accent-cyan: #00F2FE;
    }

    body { 
        background-color: var(--dark-bg); 
        background-image: 
            linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 40px 40px;
        font-family: 'Outfit', sans-serif; 
        color: #fff; 
        overflow-x: hidden;
        min-height: 100vh;
        position: relative;
    }

    /* --- Ambient Animated Orbs --- */
    .ambient-glow {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.4;
        z-index: -1;
        animation: floatOrb 15s infinite alternate ease-in-out;
    }
    .glow-red { top: -10%; left: -5%; width: 500px; height: 500px; background: rgba(211, 47, 47, 0.15); }
    .glow-blue { bottom: -10%; right: -5%; width: 600px; height: 600px; background: rgba(0, 242, 254, 0.08); animation-delay: -5s; }

    @@keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(50px, 50px) scale(1.1); }
    }

    /* --- Animations --- */
    .fade-up {
        opacity: 0;
        animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    
    @@keyframes slideUpFade {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* --- Header --- */
    .titan-header {
        padding: 2.5rem 4rem;
        background: linear-gradient(180deg, rgba(3, 5, 8, 0.9) 0%, transparent 100%);
        border-bottom: 1px solid var(--glass-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        margin-bottom: 2rem;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .brand-group h1 {
        font-size: 3.2rem;
        font-weight: 900;
        letter-spacing: -2px;
        margin: 0;
        line-height: 1;
    }
    
    .text-gradient {
        background: linear-gradient(135deg, #ff7eb3 0%, var(--eapro-red) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 0 30px var(--eapro-red-glow);
    }

    .brand-subtitle {
        font-size: 0.65rem;
        color: var(--text-muted);
        letter-spacing: 2px;
        font-weight: 600;
        text-transform: uppercase;
        margin-top: 8px;
    }

    .os-version {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        color: var(--eapro-red-light);
        letter-spacing: 4px;
        font-weight: 700;
        margin-bottom: 8px;
        display: inline-flex;
        align-items: center;
        background: rgba(211, 47, 47, 0.1);
        padding: 4px 12px;
        border-radius: 50px;
        border: 1px solid rgba(211, 47, 47, 0.2);
    }

    .status-hub { display: flex; gap: 40px; align-items: center; }
    .hub-label { font-size: 0.65rem; text-transform: uppercase; color: var(--text-muted); letter-spacing: 1.5px; font-weight: 700; display: block; margin-bottom: 4px;}
    .hub-value { font-size: 1.4rem; font-weight: 800; display: block; letter-spacing: -0.5px; }

    /* --- The Bento Matrix --- */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 24px;
        padding: 0 4rem 4rem 4rem;
        max-width: 1800px;
        margin: 0 auto;
    }

    .bento-card {
        background: var(--glass-bg);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid var(--glass-border);
        border-radius: 32px;
        padding: 2.5rem;
        transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .bento-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(circle at top right, rgba(255,255,255,0.03), transparent 60%);
        pointer-events: none;
    }

    .bento-card:hover {
        border-color: rgba(211, 47, 47, 0.3);
        transform: translateY(-5px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.4), 0 0 30px rgba(211, 47, 47, 0.05);
    }

    .card-title-neo {
        font-weight: 800;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    /* --- Terminal Component --- */
    .terminal-container {
        background: #090B10;
        border-radius: 20px;
        border: 1px solid var(--glass-border);
        overflow: hidden;
        box-shadow: inset 0 5px 20px rgba(0,0,0,0.5);
    }

    .terminal-header {
        background: rgba(255,255,255,0.03);
        padding: 10px 20px;
        display: flex;
        gap: 8px;
        border-bottom: 1px solid var(--glass-border);
    }

    .t-dot { width: 12px; height: 12px; border-radius: 50%; }
    .t-red { background: #FF5F56; }
    .t-yel { background: #FFBD2E; }
    .t-grn { background: #27C93F; }

    .terminal-output {
        font-family: 'JetBrains Mono', monospace;
        color: #00FF41;
        padding: 1.5rem 2rem;
        font-size: 0.95rem;
        line-height: 1.6;
        min-height: 120px;
    }

    /* --- Metric Grid --- */
    .mini-metrics {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 2.5rem;
    }

    .m-box {
        background: linear-gradient(145deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
        padding: 1.5rem;
        border-radius: 24px;
        border: 1px solid var(--glass-border);
        position: relative;
        overflow: hidden;
    }
    
    .m-box::after {
        content: ''; position: absolute; left: 0; bottom: 0; width: 100%; height: 3px;
        background: var(--accent-cyan); opacity: 0.5;
    }
    .m-box:nth-child(1)::after { background: #00F2FE; }
    .m-box:nth-child(2)::after { background: #27C93F; }
    .m-box:nth-child(3)::after { background: #FFBD2E; }
    .m-box:nth-child(4)::after { background: var(--eapro-red-light); }

    /* --- Navigation Pill Buttons --- */
    .nav-link-pill {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem;
        background: linear-gradient(90deg, rgba(255,255,255,0.02) 0%, transparent 100%);
        border-radius: 24px;
        border: 1px solid var(--glass-border);
        text-decoration: none !important;
        color: #fff;
        transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .pill-icon-box {
        width: 50px; height: 50px;
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem;
        background: rgba(255,255,255,0.05);
        transition: 0.4s;
    }

    .nav-link-pill:hover {
        border-color: rgba(211, 47, 47, 0.5);
        background: linear-gradient(90deg, rgba(211, 47, 47, 0.1) 0%, transparent 100%);
        transform: translateX(10px);
    }
    
    .nav-link-pill:hover .pill-icon-box {
        background: var(--eapro-red);
        box-shadow: 0 0 20px var(--eapro-red-glow);
        transform: scale(1.1);
    }

    .nav-arrow { color: var(--text-muted); transition: 0.3s; opacity: 0; transform: translateX(-10px); }
    .nav-link-pill:hover .nav-arrow { opacity: 1; transform: translateX(0); color: var(--eapro-red-light); }

    /* --- Animations --- */
    .pulse-dot {
        height: 10px; width: 10px; border-radius: 50%;
        background: #00FF41; display: inline-block;
        box-shadow: 0 0 15px #00FF41;
        margin-right: 10px;
        animation: heartBeat 1.5s infinite;
    }

    @@keyframes heartBeat {
        0% { transform: scale(0.95); opacity: 0.8; }
        50% { transform: scale(1.2); opacity: 1; }
        100% { transform: scale(0.95); opacity: 0.8; }
    }

    @@keyframes blink { 50% { opacity: 0; } }
    .cursor { animation: blink 1s step-end infinite; }
    
    /* Table Enhancements */
    .table-custom tr { transition: 0.3s; border-radius: 12px; }
    .table-custom tbody tr:hover { background: rgba(255,255,255,0.03); transform: scale(1.01); }
</style>

<div class="ambient-glow glow-red"></div>
<div class="ambient-glow glow-blue"></div>

<header class="titan-header fade-up">
    <div class="brand-group">
        <div class="os-version"><i class="fas fa-microchip me-2"></i>NEURAL_OS_v5.0</div>
        <h1>EAPRO <span class="text-gradient">ERP</span></h1>
        <div class="brand-subtitle">Energy Automation Products & Research Organization</div>
    </div>

    <div class="status-hub">
        <div class="hub-item">
            <span class="hub-label">Financial Volume</span>
            <span class="hub-value">₹142.8 <span class="text-muted fs-6">CR</span></span>
        </div>
        <div class="hub-item">
            <span class="hub-label">Intelligence Core</span>
            <span class="hub-value text-gradient">SECURED</span>
        </div>
        <div class="hub-item d-flex align-items-center bg-white bg-opacity-10 px-4 py-2 rounded-pill border border-white border-opacity-10">
            <span class="pulse-dot"></span>
            <span class="fw-bold text-white font-monospace" style="font-size: 0.8rem; letter-spacing: 1px;">SYNCING_LOCAL_S04</span>
        </div>
    </div>
</header>

<main class="bento-grid">
    
    <section class="bento-card fade-up delay-1" style="grid-column: span 8;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="card-title-neo">
                <i class="fas fa-network-wired text-danger fs-5"></i> Neural Logistics Thread
            </h5>
            <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 rounded-pill font-monospace fw-bold">ROORKEE_PLANT_NODE</span>
        </div>
        
        <div class="terminal-container">
            <div class="terminal-header">
                <div class="t-dot t-red"></div>
                <div class="t-dot t-yel"></div>
                <div class="t-dot t-grn"></div>
            </div>
            <div class="terminal-output">
                <span id="typewriter">Initializing secure handshake protocols...</span><span class="cursor">_</span>
            </div>
        </div>

        <div class="mini-metrics">
            <div class="m-box">
                <span class="hub-label">Efficiency</span>
                <div class="fw-900 fs-3 text-white">99.2<span style="color:#00F2FE; font-size: 1rem;">%</span></div>
            </div>
            <div class="m-box">
                <span class="hub-label">DSP_Load</span>
                <div class="fw-900 fs-3 text-white">88<span style="color:#27C93F; font-size: 1rem;">%</span></div>
            </div>
            <div class="m-box">
                <span class="hub-label">Thermal</span>
                <div class="fw-900 fs-3 text-white">24<span style="color:#FFBD2E; font-size: 1rem;">°C</span></div>
            </div>
            <div class="m-box">
                <span class="hub-label">Sync Ping</span>
                <div class="fw-900 fs-3 text-white">0.4<span style="color:var(--eapro-red-light); font-size: 1rem;">ms</span></div>
            </div>
        </div>
    </section>

    <section class="bento-card fade-up delay-2" style="grid-column: span 4; display: flex; flex-direction: column;">
        <h5 class="card-title-neo mb-4"><i class="fas fa-chart-line text-info fs-5"></i> Production Flux</h5>
        <div style="flex-grow: 1; position: relative;">
            <canvas id="productionChart"></canvas>
        </div>
        <div class="mt-4 p-4 rounded-4 bg-white bg-opacity-5 border border-white border-opacity-10 d-flex justify-content-between align-items-center">
            <div>
                <span class="hub-label mb-1">Live Throughput</span>
                <span class="fs-5 fw-900 text-white">Peak Capacity</span>
            </div>
            <div class="bg-success bg-opacity-20 text-success fw-900 px-3 py-2 rounded-3 fs-5">
                +14.2% <i class="fas fa-arrow-trend-up ms-1"></i>
            </div>
        </div>
    </section>

    <section class="bento-card fade-up delay-3" style="grid-column: span 9;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="card-title-neo"><i class="fas fa-users-viewfinder text-warning fs-5"></i> Operational Staff Matrix</h5>
            <a href="/Payroll/AttendanceLogs" class="btn btn-outline-light rounded-pill btn-sm fw-bold px-4 border-opacity-25 transition-hover">
                FULL DATABASE <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
        <div class="table-responsive">
            <table class="table table-borderless table-custom align-middle mb-0 text-white" style="font-size: 0.95rem;">
                <thead>
                    <tr class="hub-label border-bottom border-white border-opacity-10">
                        <th class="pb-3 px-3">Executive</th>
                        <th class="pb-3">Assignment</th>
                        <th class="pb-3 text-center">Node Status</th>
                        <th class="pb-3 text-end px-3">Last Scan</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="py-3 px-3">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center fw-900" style="width: 40px; height: 40px; box-shadow: 0 0 15px rgba(211,47,47,0.4);">AD</div>
                                <div class="fw-800 fs-6">Anuj Dhiman</div>
                            </div>
                        </td>
                        <td class="text-muted fw-600">Lead Architect (AI)</td>
                        <td class="text-center">
                            <span class="badge bg-success bg-opacity-20 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill fw-800">
                                <i class="fas fa-link me-1"></i> ACTIVE_UPLINK
                            </span>
                        </td>
                        <td class="text-end font-monospace text-white-50 px-3 fw-bold">09:14:22</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <aside class="d-flex flex-column gap-4 fade-up delay-3" style="grid-column: span 3;">
        <a href="/Inventory" class="nav-link-pill">
            <div class="d-flex align-items-center gap-4">
                <div class="pill-icon-box text-danger"><i class="fas fa-warehouse"></i></div>
                <div>
                    <h6 class="fw-900 mb-1 fs-5 text-white">Inventory</h6>
                    <small class="hub-label mb-0">Node S04 Hub</small>
                </div>
            </div>
            <i class="fas fa-chevron-right nav-arrow fs-5"></i>
        </a>
        <a href="/Dealers" class="nav-link-pill">
            <div class="d-flex align-items-center gap-4">
                <div class="pill-icon-box text-warning"><i class="fas fa-handshake"></i></div>
                <div>
                    <h6 class="fw-900 mb-1 fs-5 text-white">Dealers</h6>
                    <small class="hub-label mb-0">Global Network</small>
                </div>
            </div>
            <i class="fas fa-chevron-right nav-arrow fs-5"></i>
        </a>
        <a href="/SolarProjects" class="nav-link-pill">
            <div class="d-flex align-items-center gap-4">
                <div class="pill-icon-box text-info"><i class="fas fa-bolt"></i></div>
                <div>
                    <h6 class="fw-900 mb-1 fs-5 text-white">Projects</h6>
                    <small class="hub-label mb-0">Live Deployments</small>
                </div>
            </div>
            <i class="fas fa-chevron-right nav-arrow fs-5"></i>
        </a>
    </aside>
</main>

@section Scripts {
    <script>
        // 1. High-Precision Flow Graph
        const ctx = document.getElementById('productionChart').getContext('2d');
        
        // Premium Gradient Fill
        const gradient = ctx.createLinearGradient(0, 0, 0, 200);
        gradient.addColorStop(0, 'rgba(211, 47, 47, 0.6)');
        gradient.addColorStop(1, 'rgba(211, 47, 47, 0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['8am', '10am', '12pm', '2pm', '4pm', '6pm', '8pm'],
                datasets: [{
                    data: [25, 45, 65, 55, 80, 70, 95],
                    borderColor: '#FF3131',
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.4, // Smooth curves
                    borderWidth: 4,
                    pointRadius: 4,
                    pointBackgroundColor: '#030508',
                    pointBorderColor: '#FF3131',
                    pointBorderWidth: 2,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { family: 'Outfit', size: 14, weight: 'bold' },
                        bodyFont: { family: 'JetBrains Mono', size: 13 },
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false
                    }
                },
                scales: { 
                    y: { display: false, min: 0 }, 
                    x: { 
                        ticks: { color: '#8B9BB4', font: { family: 'Outfit', weight: '700', size: 11 } }, 
                        grid: { display: false } 
                    } 
                },
                interaction: { intersect: false, mode: 'index' }
            }
        });

        // 2. High-Speed Neural Typewriter
        const logs = [
            "Initiating secure neural handshake... [OK]",
            "Decrypting remote data packets...",
            "Analyzing Roorkee Plant throughput... DSP stable at 99.8%.",
            "Mercury PCU Batch #142 passed AI quality verification.",
            "Syncing Dealer Network: Apex Solar confirmed ₹25L volume.",
            "Titan OS integrity checks completed. System nominal."
        ];
        let i = 0, j = 0, isDeleting = false;
        const target = document.getElementById('typewriter');

        function loop() {
            const currentLine = logs[i];
            if (isDeleting) {
                target.innerText = currentLine.substring(0, j--);
                if (j < 0) { isDeleting = false; i = (i + 1) % logs.length; }
            } else {
                target.innerText = currentLine.substring(0, j++);
                if (j > currentLine.length) { 
                    isDeleting = true; 
                    // Pause longer at the end of a sentence
                    setTimeout(loop, 3000); 
                    return; 
                }
            }
            // Randomize typing speed slightly for realism
            const typingSpeed = isDeleting ? 15 : Math.random() * 30 + 30;
            setTimeout(loop, typingSpeed);
        }
        
        // Start typing effect after a small delay
        setTimeout(loop, 1000);
    </script>
}