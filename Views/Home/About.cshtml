@{
    ViewData["Title"] = "About Us | EAPRO ERP";
}

<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-red-bright: #ff4d4d;
        --dark-bg: #0A0C12;
        --glass-bg: rgba(15, 23, 42, 0.65); 
        --glass-border: rgba(255, 255, 255, 0.12);
        --text-primary: #F8FAFC; 
        --text-secondary: #CBD5E1; 
    }

    body { 
        background-color: var(--dark-bg); 
        background-image: 
            linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        font-family: 'Plus Jakarta Sans', sans-serif; 
        color: var(--text-primary); 
        overflow-x: hidden;
    }

    /* --- Ambient Orbs --- */
    .ambient-glow {
        position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.4; z-index: -1; animation: floatOrb 15s infinite alternate ease-in-out;
    }
    .glow-red { top: -5%; right: -5%; width: 500px; height: 500px; background: rgba(211, 47, 47, 0.25); }
    .glow-blue { bottom: 20%; left: -10%; width: 600px; height: 600px; background: rgba(14, 165, 233, 0.15); animation-delay: -5s; }

    @@keyframes floatOrb {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(-50px, 50px) scale(1.1); }
    }

    .about-wrapper { max-width: 1400px; margin: 0 auto; padding: 5rem 2rem; position: relative; z-index: 10; }

    /* --- Typography Upgrades --- */
    .hero-title { font-family: 'Outfit', sans-serif; font-size: 4.5rem; font-weight: 900; letter-spacing: -2px; line-height: 1.1; margin-bottom: 1.5rem; color: #fff; }
    
    .section-title { font-family: 'Outfit', sans-serif; font-size: 3rem; font-weight: 900; color: #fff; margin-bottom: 3rem; letter-spacing: -1px; text-align: center; }

    .text-gradient-red {
        background: linear-gradient(135deg, #ff9a9e 0%, var(--eapro-red-bright) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        text-shadow: 0 10px 30px rgba(211, 47, 47, 0.3);
    }

    .lead-text { font-size: 1.3rem; color: var(--text-secondary); line-height: 1.8; font-weight: 500; letter-spacing: 0.2px; }

    /* --- Bento Box UI --- */
    .bento-card {
        background: var(--glass-bg); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border); border-radius: 32px; padding: 3rem;
        transition: all 0.4s ease; position: relative; overflow: hidden; height: 100%;
        box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .bento-card:hover {
        border-color: rgba(255, 255, 255, 0.25); transform: translateY(-8px);
        box-shadow: 0 30px 60px rgba(0,0,0,0.5), 0 0 30px rgba(211, 47, 47, 0.1);
    }

    .card-heading { font-family: 'Outfit', sans-serif; font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 1rem; letter-spacing: -0.5px; }
    .card-body-text { font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; font-weight: 500; }

    .icon-box {
        width: 70px; height: 70px; border-radius: 20px; background: rgba(255,255,255,0.08);
        display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin-bottom: 2rem;
        border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

    .metric-number { font-size: 4rem; font-weight: 900; line-height: 1; margin-bottom: 0.8rem; font-family: 'JetBrains Mono', monospace; color: #fff; }
    .metric-label { color: var(--text-secondary); font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; font-size: 0.9rem; }

    /* --- Leadership Section --- */
    .profile-card {
        display: flex; gap: 2rem; align-items: center; background: rgba(0,0,0,0.3);
        border-radius: 24px; padding: 2rem; border: 1px solid var(--glass-border);
    }
    .profile-avatar {
        width: 110px; height: 110px; border-radius: 30px;
        background: linear-gradient(135deg, var(--eapro-red), #ff7043);
        display: flex; align-items: center; justify-content: center;
        font-size: 3rem; font-weight: 900; color: #fff;
        box-shadow: 0 15px 30px rgba(211, 47, 47, 0.4); flex-shrink: 0; font-family: 'Outfit', sans-serif;
    }

    /* --- Group of Companies Section --- */
    .company-card-neo {
        background: linear-gradient(145deg, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px solid var(--glass-border);
        border-radius: 24px; padding: 2.5rem; transition: 0.4s ease; position: relative; overflow: hidden;
    }
    .company-card-neo:hover {
        background: rgba(211,47,47,0.05); border-color: rgba(211,47,47,0.3);
        transform: translateY(-8px); box-shadow: 0 15px 30px rgba(0,0,0,0.3);
    }
    .company-icon-large { font-size: 2.5rem; color: var(--text-secondary); transition: 0.3s; }
    .company-card-neo:hover .company-icon-large { color: var(--eapro-red-bright); transform: scale(1.1); }
    
    /* --- Achievements Timeline --- */
    .timeline-container { display: flex; overflow-x: auto; gap: 2rem; padding: 2rem 0; scrollbar-width: none; }
    .timeline-container::-webkit-scrollbar { display: none; }
    .timeline-item {
        min-width: 380px; background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, transparent 100%);
        border: 1px solid var(--glass-border); border-radius: 24px; padding: 2.5rem; position: relative;
    }
    .timeline-item::before { content: ''; position: absolute; top: 0; left: 2.5rem; width: 40px; height: 4px; background: var(--eapro-red); }

    /* Animations */
    .fade-up { opacity: 0; animation: slideUpFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    .d-1 { animation-delay: 0.1s; } .d-2 { animation-delay: 0.2s; } .d-3 { animation-delay: 0.3s; } .d-4 { animation-delay: 0.4s; } .d-5 { animation-delay: 0.5s; }

    @@keyframes slideUpFade { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="ambient-glow glow-red"></div>
<div class="ambient-glow glow-blue"></div>

<div class="about-wrapper">
    
    <div class="text-center mb-5 pb-4 fade-up">
        <div class="badge bg-danger bg-opacity-10 text-danger border border-danger px-4 py-2 rounded-pill font-monospace fw-bold mb-4" style="letter-spacing: 3px; font-size: 0.85rem;">
            ESTABLISHED 2012
        </div>
        <h1 class="hero-title">Energy Automation Products<br>& <span class="text-gradient-red">Research Organization</span></h1>
    </div>

    <div class="row mb-5 pb-3 fade-up d-1">
        <div class="col-12">
            <div class="bento-card">
                <div class="row align-items-center">
                    <div class="col-lg-5 mb-4 mb-lg-0 pr-lg-5">
                        <div class="icon-box text-danger mb-4" style="width: 80px; height: 80px; font-size: 2rem;"><i class="fas fa-bolt-lightning"></i></div>
                        <h2 class="card-heading" style="font-size: 3rem; line-height: 1.1;">Driving <span class="text-gradient-red">Innovation</span> & Sustainability</h2>
                        <p class="lead-text mt-4">We are a leading provider of advanced, energy-efficient technologies designed to meet the needs of today’s evolving industries.</p>
                    </div>
                    <div class="col-lg-7">
                        <div class="ps-lg-5" style="border-left: 1px solid var(--glass-border);">
                            <p class="card-body-text fs-5 mb-4 text-white">With a clear focus on sustainability and innovation, EAPRO delivers high-performance solutions that drive operational efficiency and support environmental responsibility.</p>
                            <p class="card-body-text mb-4">Specializing in both solar and non-solar applications, EAPRO has earned a reputation for technical excellence, reliability, and continuous innovation. Our portfolio is anchored by pure sine wave inverters, where we have consistently set industry benchmarks for performance, durability, and quality. Complemented by a diverse range of energy solutions, our products are engineered to support businesses in optimizing energy use and reducing costs.</p>
                            <p class="card-body-text mb-4">At EAPRO, research and development are at the core of our operations. Our dedicated team of engineers, researchers, and manufacturing specialists works closely to anticipate market demands and deliver tailored solutions that meet the unique requirements of our partners and clients across sectors.</p>
                            <p class="card-body-text mb-0">We are committed to providing cost-effective, scalable, and sustainable technologies that enable our clients to maintain a competitive edge. As a trusted partner to businesses worldwide, EAPRO remains focused on driving innovation, strengthening industry partnerships, and contributing to a more sustainable global energy landscape.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5 fade-up d-2">
        <div class="col-lg-4">
            <div class="bento-card">
                <div class="icon-box text-info"><i class="fas fa-eye"></i></div>
                <h3 class="card-heading">Our Vision</h3>
                <p class="card-body-text">To be India's No. 1 Power and Solar Solutions Provider Company, setting industry benchmarks in technical excellence, sustainability, and being among India's Top 10 Best Employers.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="bento-card" style="background: rgba(211,47,47,0.1); border-color: rgba(211,47,47,0.3);">
                <div class="icon-box text-white" style="background: var(--eapro-red); border-color: #ff4d4d;"><i class="fas fa-bullseye"></i></div>
                <h3 class="card-heading">Our Mission</h3>
                <p class="card-body-text text-white opacity-75">To become the World's No. 1 brand in Solar Inverter Technology. We aim to bring futuristic, eco-friendly energy automation products to the people at an affordable cost through continuous R&D.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="bento-card">
                <div class="icon-box text-success"><i class="fas fa-scale-balanced"></i></div>
                <h3 class="card-heading">Our Values</h3>
                <p class="card-body-text">Integrity in EAPRO is more than making right calls—it's about a strong moral compass. Accountability ensures we deliver an individual faith to our customers with every product.</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5 pb-5 fade-up d-3">
        <div class="col-lg-6">
            <div class="bento-card h-100 p-5">
                <div class="d-flex align-items-center gap-4 mb-5">
                    <div class="icon-box text-danger mb-0" style="width: 80px; height: 80px; font-size: 2rem;"><i class="fas fa-microchip"></i></div>
                    <h3 class="card-heading mb-0" style="font-size: 2.5rem;">The Legacy</h3>
                </div>
                <p class="card-body-text fs-5 mb-4">
                    In 2002, our founder pioneered a revolutionary stride in the power sector by inventing <strong class="text-white">DSP Sine Wave Technology</strong>. This innovation paved the way for EAPRO's inception in 2012. 
                </p>
                <p class="card-body-text fs-5 mb-0">
                    Today, operating out of the Salempur Rajputana Industrial Area in Roorkee, Uttarakhand, EAPRO boasts an impressive facility capable of producing 50,000 power backup & solar hybrid inverters monthly. Recognized with the "Start-up to Unicorn Accolade" by the Govt. of India, we continue to drive the nation's transition toward clean, sustainable solar energy.
                </p>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="bento-card h-100 d-flex flex-column justify-content-center gap-4 p-5">
                <div class="profile-card">
                    <div class="profile-avatar">JC</div>
                    <div>
                        <h4 class="card-heading mb-1 fs-3">Jagdeep Chauhan</h4>
                        <div class="text-danger fw-800 small text-uppercase mb-3" style="letter-spacing: 1.5px;">Founder & Managing Director</div>
                        
                    </div>
                </div>
                
                <div class="profile-card">
                    <div class="profile-avatar" style="background: linear-gradient(135deg, #334155, #0f172a); box-shadow: 0 15px 30px rgba(0,0,0,0.5);">AS</div>
                    <div>
                        <h4 class="card-heading mb-1 fs-3">Abhilasha Singh</h4>
                        <div class="text-info fw-800 small text-uppercase mb-3" style="letter-spacing: 1.5px;">Director</div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-5 pb-5 fade-up d-4">
