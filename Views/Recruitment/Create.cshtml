@model EaproERP.Models.Candidate
@{ ViewData["Title"] = "Source Talent"; }

<style>
    :root {
        --titan-red: #D32F2F;
        --titan-dark: #0F172A;
        --titan-border: #E2E8F0;
    }

    .source-wrapper { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    
    .source-card { 
        background: #ffffff; 
        border: 1px solid var(--titan-border); 
        border-radius: 32px; 
        padding: 4rem; 
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08);
        max-width: 950px;
        margin: 2rem auto;
        position: relative;
        overflow: hidden;
    }

    /* Top decorative gradient line */
    .source-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 6px;
        background: linear-gradient(90deg, var(--titan-red), #ff7043);
    }

    .form-label-custom {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #64748B;
        margin-bottom: 12px;
        display: block;
        padding-left: 5px;
    }

    /* --- Premium Input Fields with Icons --- */
    .input-wrapper { position: relative; }
    
    .input-premium {
        background: #F8FAFC;
        border: 2px solid #F1F5F9;
        border-radius: 18px;
        padding: 16px 20px 16px 55px; /* Extra left padding for icon */
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--titan-dark);
        width: 100%;
        transition: all 0.3s ease;
    }

    /* File input specific styling to align the text beautifully */
    input[type="file"].input-premium {
        padding: 13px 20px 13px 55px;
        color: #64748B;
    }
    input[type="file"].input-premium::file-selector-button {
        background: var(--titan-dark);
        color: white;
        border: none;
        padding: 6px 16px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.8rem;
        margin-right: 15px;
        transition: 0.3s;
        cursor: pointer;
    }
    input[type="file"].input-premium::file-selector-button:hover {
        background: var(--titan-red);
    }

    .input-premium::placeholder { color: #CBD5E1; font-weight: 500; }

    .input-premium:focus {
        background: #ffffff;
        border-color: var(--titan-red);
        box-shadow: 0 0 0 4px rgba(211, 47, 47, 0.1);
        outline: none;
    }

    .input-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #94A3B8;
        font-size: 1.1rem;
        transition: color 0.3s ease;
        pointer-events: none; /* Prevents icon from blocking clicks */
    }

    /* Icon lights up when input is focused */
    .input-premium:focus ~ .input-icon { color: var(--titan-red); }

    .select-premium { padding-right: 40px; cursor: pointer; }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container source-wrapper">
    <div class="source-card">
        
        <div class="d-flex justify-content-between align-items-center mb-5 pb-4 border-bottom">
            <div class="d-flex align-items-center gap-4">
                <div class="bg-danger d-flex align-items-center justify-content-center rounded-circle shadow-sm" style="width: 65px; height: 65px;">
                    <i class="fas fa-user-astronaut text-white fs-3"></i>
                </div>
                <div>
                    <h2 class="fw-800 text-dark mb-0" style="letter-spacing: -1px;">Source <span class="text-danger">Talent</span></h2>
                    <div class="d-flex align-items-center gap-2 mt-1">
                        <div class="spinner-grow text-success" style="width: 8px; height: 8px;" role="status"></div>
                        <span class="text-muted fw-bold font-monospace" style="font-size: 0.7rem;">TITAN_RECRUITMENT_NODE_ACTIVE</span>
                    </div>
                </div>
            </div>
            <div class="text-end d-none d-md-block">
                <p class="text-muted fw-bold mb-0 small uppercase">Step 01 / 05</p>
                <h6 class="fw-800 text-dark mb-0">Initial Screening</h6>
            </div>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="row g-5">
                
                <div class="col-md-6">
                    <label class="form-label-custom">Candidate Full Name</label>
                    <div class="input-wrapper">
                        <input asp-for="Name" class="form-control input-premium" placeholder="e.g. Rahul Sharma" required autocomplete="off" />
                        <i class="fas fa-id-card input-icon"></i>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <label class="form-label-custom">Primary Email Address</label>
                    <div class="input-wrapper">
                        <input asp-for="Email" type="email" class="form-control input-premium" placeholder="candidate@example.com" required autocomplete="off" />
                        <i class="fas fa-envelope input-icon"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Target Position</label>
                    <div class="input-wrapper">
                        <select asp-for="Position" class="form-select input-premium select-premium">
                            <option value="GenAI Developer">GenAI Developer</option>
                            <option value="AI Researcher">AI Researcher</option>
                            <option value="Full Stack Developer">Full Stack Developer</option>
                            <option value="Business Analyst">Business Analyst</option>
                            <option value="Embedded Systems Engineer">Embedded Systems Engineer</option>
                            <option value="Technical Sales Executive">Technical Sales Executive</option>
                        </select>
                        <i class="fas fa-crosshairs input-icon"></i>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="form-label-custom">Upload Resume Document</label>
                    <div class="input-wrapper">
                        <input type="file" name="resumeFile" class="form-control input-premium" accept=".pdf,.doc,.docx" />
                        <i class="fas fa-file-upload input-icon"></i>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label-custom">Portfolio / LinkedIn URL (Optional)</label>
                    <div class="input-wrapper">
                        <input asp-for="ResumeUrl" class="form-control input-premium" placeholder="https://linkedin.com/in/..." autocomplete="off" />
                        <i class="fas fa-link input-icon"></i>
                    </div>
                </div>
                
                <div class="col-12 mt-5 pt-3">
                    <div class="d-flex justify-content-between align-items-center p-4 bg-light rounded-4 border">
                        <a asp-action="Pipeline" class="text-muted fw-bold text-decoration-none small transition-hover">
                            <i class="fas fa-arrow-left me-2"></i> Cancel & Return
                        </a>
                        <button type="submit" class="btn btn-dark rounded-pill px-5 py-3 fw-800 shadow-lg" style="transition: 0.3s; transform: translateY(0);">
                            Register Candidate <i class="fas fa-satellite-dish ms-2"></i>
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>