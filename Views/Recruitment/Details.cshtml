@model EaproERP.Models.Candidate
@{ ViewData["Title"] = "Candidate Dossier"; }

<style>
    :root {
        --titan-red: #D32F2F;
        --titan-dark: #0F172A;
        --titan-border: #E2E8F0;
        --titan-bg: #F8FAFC;
    }

    .dossier-wrapper { animation: fadeIn 0.4s ease-out; }
    
    .profile-header-card {
        background: #fff; border: 1px solid var(--titan-border); border-radius: 24px;
        padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); position: relative; overflow: hidden;
    }
    
    .profile-header-card::before {
        content: ''; position: absolute; top: 0; left: 0; width: 6px; height: 100%; 
        background: linear-gradient(180deg, var(--titan-red), #ff7043);
    }

    .info-card {
        background: #fff; border: 1px solid var(--titan-border); border-radius: 24px;
        padding: 35px; height: 100%; box-shadow: 0 5px 15px rgba(0,0,0,0.02);
    }

    .avatar-large {
        width: 85px; height: 85px; border-radius: 50%; background: #FFF1F2;
        color: var(--titan-red); display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 2.2rem; border: 2px solid #FECACA;
    }

    .data-label { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: #94A3B8; margin-bottom: 5px; }
    .data-value { font-size: 1.05rem; font-weight: 700; color: var(--titan-dark); }

    /* Vertical Timeline */
    .timeline { position: relative; padding-left: 35px; margin-top: 25px; }
    .timeline::before { content: ''; position: absolute; left: 7px; top: 0; height: 100%; width: 2px; background: var(--titan-border); }
    
    .timeline-item { position: relative; margin-bottom: 30px; }
    .timeline-dot {
        position: absolute; left: -35px; top: 2px; width: 16px; height: 16px;
        border-radius: 50%; background: #fff; border: 3px solid var(--titan-border); z-index: 1; transition: 0.3s;
    }
    .timeline-item.active .timeline-dot { border-color: var(--titan-red); background: #fff; transform: scale(1.2); box-shadow: 0 0 12px rgba(211, 47, 47, 0.3); }
    .timeline-item.completed .timeline-dot { border-color: var(--titan-red); background: var(--titan-red); }

    /* Custom Textarea for Notes */
    .note-input {
        background: #F8FAFC; border: 2px solid #F1F5F9; border-radius: 16px;
        padding: 15px; font-weight: 500; font-size: 0.9rem; color: var(--titan-dark);
        transition: 0.3s; resize: none;
    }
    .note-input:focus { background: #fff; border-color: var(--titan-red); box-shadow: 0 0 0 4px rgba(211, 47, 47, 0.1); outline: none; }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="py-4 dossier-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="CandidateArchive" class="text-muted fw-bold text-decoration-none small transition-hover">
            <i class="fas fa-arrow-left me-2"></i> Return to Archive
        </a>
        <div class="badge bg-dark rounded-pill px-4 py-2 fw-800 font-monospace" style="letter-spacing: 1px;">ID: EAP-CAND-@Model.Id.ToString("D4")</div>
    </div>

    <div class="profile-header-card mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-4">
                <div class="avatar-large shadow-sm">
                    @Model.Name.Substring(0, 1).ToUpper()
                </div>
                <div>
                    <h1 class="fw-900 mb-1" style="letter-spacing: -1px; color: var(--titan-dark);">@Model.Name</h1>
                    <h5 class="text-danger fw-800 mb-2 font-monospace" style="font-size: 0.9rem;">@Model.Position.ToUpper()</h5>
                    
                    <div class="mt-2">
                        @if (Model.Status == "Hired") { <span class="badge bg-success-subtle text-success border border-success px-3 py-2 rounded-pill fw-800"><i class="fas fa-check-circle me-1"></i> OFFICIALLY HIRED</span> }
                        else if (Model.Status == "Rejected") { <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-2 rounded-pill fw-800"><i class="fas fa-times-circle me-1"></i> REJECTED / ARCHIVED</span> }
                        else { <span class="badge bg-warning-subtle text-warning border border-warning px-3 py-2 rounded-pill fw-800"><i class="fas fa-spinner fa-spin me-1"></i> ACTIVE IN PIPELINE</span> }
                    </div>
                </div>
            </div>

            <div class="text-end d-none d-md-flex gap-2">
                @if (Model.Status == "Active")
                {
                    <form id="reject-form-@Model.Id" asp-action="RejectCandidate" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="button" onclick="confirmReject(@Model.Id, '@Model.Name')" class="btn btn-outline-dark rounded-pill px-4 py-3 fw-800 shadow-sm border-2">
                            <i class="fas fa-ban me-2"></i> Reject
                        </button>
                    </form>
                }

                @if (!string.IsNullOrEmpty(Model.ResumeUrl))
                {
                    <a href="@Model.ResumeUrl" target="_blank" class="btn btn-danger rounded-pill px-4 py-3 fw-800 shadow-sm">
                        <i class="fas fa-file-pdf me-2"></i> Original Resume
                    </a>
                }
                else
                {
                    <button class="btn btn-light rounded-pill px-4 py-3 fw-800 text-muted border-2" disabled>
                        <i class="fas fa-file-excel me-2"></i> No Resume
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="info-card d-flex flex-column">
                <h6 class="fw-800 border-bottom pb-3 mb-4"><i class="fas fa-address-card text-muted me-2"></i> Intelligence Summary</h6>
                
                <div class="row g-4 mb-4">
                    <div class="col-sm-6">
                        <div class="data-label">Primary Email</div>
                        <div class="data-value"><i class="fas fa-envelope text-danger me-2 small"></i> @Model.Email</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="data-label">Application Date</div>
                        <div class="data-value"><i class="fas fa-calendar-day text-danger me-2 small"></i> @Model.AppliedDate.ToString("dd MMMM, yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="data-label">System Tracking ID</div>
                        <div class="data-value font-monospace">EAP-HR-@Model.Id.ToString("D6")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="data-label">Offer Generation Status</div>
                        <div class="data-value">
                            @(Model.CurrentStep == 5 || Model.Status == "Hired" ? "Issued & Logged" : "Pending Evaluation")
                        </div>
                    </div>
                </div>

                <div class="mt-auto pt-4 border-top">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="data-label mb-0"><i class="fas fa-robot text-danger me-1"></i> HR Interview Notes</div>
                        <span class="badge bg-light text-muted border fw-bold small">Encrypted Log</span>
                    </div>
                    
                    <form asp-action="UpdateNotes" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <textarea name="notes" class="form-control note-input mb-3" rows="4" placeholder="Enter interview feedback, salary expectations, or technical review notes here...">@Model.Notes</textarea>
                        <div class="text-end">
                            <button type="submit" class="btn btn-dark rounded-pill px-4 py-2 fw-800 shadow-sm">
                                Save Log <i class="fas fa-save ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        </div>

        <div class="col-lg-5">
            <div class="info-card">
                <h6 class="fw-800 border-bottom pb-3 mb-4"><i class="fas fa-route text-muted me-2"></i> Recruitment Journey</h6>
                
                <div class="timeline">
                    @{
                        var stages = new[] { 
                            new { Name = "Application Received", Desc = "Candidate entered into Titan OS." },
                            new { Name = "Technical Evaluation", Desc = "Skills & aptitude screening." },
                            new { Name = "HR Screening", Desc = "Culture fit & background check." },
                            new { Name = "Management Interview", Desc = "Final clearance & salary negotiation." },
                            new { Name = "Offer & Onboarding", Desc = "Offer letter generated." }
                        };

                        for (int i = 1; i <= 5; i++)
                        {
                            var status = Model.CurrentStep > i || Model.Status == "Hired" ? "completed" : (Model.CurrentStep == i ? "active" : "");
                            var color = status == "completed" ? "text-dark" : (status == "active" ? "text-danger" : "text-muted");

                            <div class="timeline-item @status">
                                <div class="timeline-dot"></div>
                                <h6 class="fw-800 mb-1 @color" style="letter-spacing: -0.5px;">@stages[i-1].Name</h6>
                                <p class="small text-muted mb-0 fw-bold">@stages[i-1].Desc</p>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Reject Candidate Confirmation
        function confirmReject(id, name) {
            Swal.fire({
                title: 'Disqualify Candidate?',
                text: `Are you sure you want to reject ${name}? This will remove them from the active pipeline.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#D32F2F', // Eapro Red
                cancelButtonColor: '#0F172A',
                confirmButtonText: 'Yes, Reject Candidate'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('reject-form-' + id).submit();
                }
            });
        }

        // Success Notification Listener for Saved Notes
        document.addEventListener("DOMContentLoaded", function() {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    title: 'System Update',
                    text: '@TempData["SuccessMessage"]',
                    icon: 'success',
                    confirmButtonColor: '#D32F2F',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-4 shadow-lg border',
                        title: 'fw-800 text-dark',
                        confirmButton: 'rounded-pill px-4 fw-800'
                    }
                });
                </text>
            }
        });
    </script>
}