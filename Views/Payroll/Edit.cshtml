@model EaproERP.Models.Employee
@{ 
    ViewData["Title"] = "Edit Employee Profile"; 
}

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --input-bg: #F8FAFC;
    }

    .edit-container { animation: slideInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1); }
    
    /* Profile Header Card */
    .profile-header-card {
        background: linear-gradient(135deg, var(--eapro-slate) 0%, #0F172A 100%);
        border-radius: 28px;
        padding: 2.5rem;
        color: white;
        margin-bottom: -40px;
        position: relative;
        z-index: 2;
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    /* Main Edit Card */
    .edit-card {
        background: white;
        border-radius: 35px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
        padding: 6rem 3rem 3rem 3rem; /* Extra top padding to accommodate overlapping header */
    }

    .section-divider {
        display: flex;
        align-items: center;
        gap: 15px;
        margin: 3rem 0 2rem 0;
    }
    .section-divider span {
        font-size: 0.75rem;
        font-weight: 800;
        color: #94A3B8;
        text-transform: uppercase;
        letter-spacing: 2px;
        white-space: nowrap;
    }
    .section-line { height: 1px; background: #f1f5f9; width: 100%; }

    .input-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 8px;
        display: block;
    }

    .form-control, .form-select {
        border-radius: 16px;
        background: var(--input-bg);
        border: 1px solid #E2E8F0;
        padding: 14px 18px;
        font-weight: 600;
        color: var(--eapro-slate);
        transition: all 0.3s;
    }

    .form-control:focus {
        background: white;
        border-color: var(--eapro-red);
        box-shadow: 0 0 0 4px rgba(211, 47, 47, 0.1);
        transform: translateY(-2px);
    }

    .btn-update {
        background: var(--eapro-red);
        color: white;
        border: none;
        border-radius: 100px;
        padding: 18px 45px;
        font-weight: 800;
        letter-spacing: 1px;
        box-shadow: 0 15px 30px rgba(211, 47, 47, 0.2);
        transition: 0.4s;
    }

    .btn-update:hover {
        background: #B91C1C;
        transform: scale(1.05);
        box-shadow: 0 20px 40px rgba(211, 47, 47, 0.3);
    }

    @@keyframes slideInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container edit-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="profile-header-card">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="bg-danger rounded-4 d-flex align-items-center justify-content-center shadow-lg" style="width: 80px; height: 80px;">
                            <i class="fas fa-user-gear fs-2"></i>
                        </div>
                    </div>
                    <div class="col">
                        <span class="badge bg-danger bg-opacity-25 text-danger px-3 py-2 rounded-pill fw-800 mb-2">PERSONNEL RECORD UPDATE</span>
                        <h2 class="fw-800 mb-0">@Model.Name</h2>
                        <p class="text-white-50 mb-0 fw-500">System ID: <span class="text-white">@Model.EmployeeCode</span> | Accessing Local Data Node</p>
                    </div>
                    <div class="col-auto text-end">
                        <div class="small fw-bold opacity-50 mb-1">AI INSIGHT STATUS</div>
                        <span class="text-success fw-800"><i class="fas fa-circle-check me-2"></i>SYNCHRONIZED</span>
                    </div>
                </div>
            </div>

            <div class="edit-card">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="AIPerformanceInsight" />
                    <input type="hidden" asp-for="BiometricCredentialId" />
                    <input type="hidden" asp-for="BiometricPublicKey" />

                    @if (!ViewData.ModelState.IsValid) {
                        <div class="alert alert-danger border-0 rounded-4 mb-5 d-flex align-items-center gap-3">
                            <i class="fas fa-triangle-exclamation fs-3"></i>
                            <div class="fw-bold">Validation Error: Please review the highlighted fields below.</div>
                        </div>
                    }

                    <div class="section-divider">
                        <span><i class="fas fa-id-badge me-2 text-danger"></i>Core Identity</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label class="input-label">Legal Name</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Scanner Barcode ID (Kiosk Auth)</label>
                            <input asp-for="EmployeeCode" class="form-control border-danger bg-danger bg-opacity-10 fw-800 text-danger" required />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Primary Phone</label>
                            <input asp-for="Phone" class="form-control" placeholder="+91..." />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Business Email</label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="name@eapro.in" />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Emergency Contact</label>
                            <input asp-for="EmergencyContact" class="form-control" />
                        </div>
                    </div>

                    <div class="section-divider">
                        <span><i class="fas fa-briefcase me-2 text-danger"></i>Deployment & Payroll</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-4">
                            <label class="input-label">Department</label>
                            <select asp-for="Department" class="form-select">
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="R&D">Research & Development</option>
                                <option value="Logistics">Inventory & Logistics</option>
                                <option value="Corporate">Corporate HQ</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Designation</label>
                            <select asp-for="Designation" class="form-select">
                                <option value="General Manager">General Manager</option>
                                <option value="Plant Manager">Plant Manager</option>
                                <option value="Deputy Manager">Deputy Manager</option>
                                <option value="Senior Solar Engineer">Senior Solar Engineer</option>
                                <option value="Full Stack Developer">Full Stack Developer</option>
                                <option value="Business Analyst">Business Analyst</option>
                                <option value="Production Supervisor">Production Supervisor</option>
                                <option value="Line Lead">Line Lead</option>
                                <option value="Inventory Controller">Inventory Controller</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Job Location</label>
                            <select asp-for="JobLocation" class="form-select">
                                <option value="Roorkee">Roorkee Unit</option>
                                <option value="Meerut">Meerut Office</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Base Salary (₹)</label>
                            <input asp-for="BaseSalary" type="number" step="0.01" class="form-control fw-800 text-success" required />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Performance Bonus (₹)</label>
                            <input asp-for="Bonus" type="number" step="0.01" class="form-control fw-bold" />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Date of Joining</label>
                            <input asp-for="DateOfJoining" type="date" value="@Model.DateOfJoining.ToString("yyyy-MM-dd")" class="form-control" required />
                        </div>
                    </div>

                    <div class="section-divider">
                        <span><i class="fas fa-vault me-2 text-danger"></i>Compliance & Settlement</span>
                        <div class="section-line"></div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-4">
                            <label class="input-label">Aadhar / PAN</label>
                            <input asp-for="GovernmentId" class="form-control" style="text-transform: uppercase;" />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Settlement Account</label>
                            <input asp-for="BankAccountNumber" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">IFSC Code</label>
                            <input asp-for="IFSCCode" class="form-control" style="text-transform: uppercase;" />
                        </div>
                    </div>

                    <div class="mt-5 pt-5 d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="text-decoration-none text-muted fw-800 small uppercase"><i class="fas fa-chevron-left me-2"></i>Cancel Modification</a>
                        <button type="submit" class="btn-update shadow-lg">
                            SYNC RECORD & RE-RUN AI <i class="fas fa-bolt ms-2"></i>
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>