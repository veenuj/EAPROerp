@model EaproERP.Models.Employee
@{ ViewData["Title"] = "Biometric Enrollment"; }

<div class="container py-5 text-center">
    <div class="card shadow-lg p-4 rounded-4 border-0">
        <i class="fas fa-fingerprint text-danger mb-3" style="font-size: 4rem;"></i>
        <h2 class="fw-800">Register Biometrics</h2>
        <p class="text-muted">Link your Phone's Fingerprint or FaceID to: <br><strong>@Model.Name</strong></p>
        
        <button id="enrollBtn" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold mt-4">
            Start Enrollment
        </button>
        <div id="status" class="mt-3 small fw-bold"></div>
    </div>
</div>

<script>
    document.getElementById('enrollBtn').onclick = async () => {
        const status = document.getElementById('status');
        status.innerText = "Check your phone's biometric prompt...";

        // 1. Generate random challenge from server (simplified for now)
        const challenge = new Uint8Array(32); window.crypto.getRandomValues(challenge);
        const userId = new Uint8Array(16); window.crypto.getRandomValues(userId);

        const options = {
            publicKey: {
                challenge: challenge,
                rp: { name: "EAPRO ERP" },
                user: {
                    id: userId,
                    name: "@Model.Email",
                    displayName: "@Model.Name"
                },
                pubKeyCredParams: [{ alg: -7, type: "public-key" }], // ES256
                authenticatorSelection: { userVerification: "required" },
                timeout: 60000
            }
        };

        try {
            // 2. Trigger native phone Fingerprint/FaceID
            const credential = await navigator.credentials.create(options);
            
            // 3. Send raw data to Controller to save in DB
            // In a real app, you would base64 encode 'credential.rawId' and 'credential.response.attestationObject'
            status.innerHTML = "<span class='text-success'>Success! Device Linked.</span>";
            
        } catch (err) {
            status.innerHTML = "<span class='text-danger'>Enrollment Failed or Cancelled.</span>";
        }
    };
</script>