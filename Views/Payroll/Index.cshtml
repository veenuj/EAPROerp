@model IEnumerable<EaproERP.Models.Employee>
@{
    ViewData["Title"] = "Payroll Matrix";
}

<style>
    /* --- Premium Personnel Matrix Styling --- */
    .payroll-container {
        animation: fadeIn 0.6s ease-out;
    }

    .matrix-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 28px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    /* List Item Styling */
    .employee-row {
        transition: all 0.3s ease;
        border-bottom: 1px solid #f1f5f9;
        padding: 1.5rem;
    }

    .employee-row:hover {
        background: #f8fafc;
        transform: scale(1.01);
    }

    .emp-avatar {
        width: 50px;
        height: 50px;
        background: var(--eapro-dark);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        font-weight: 800;
        font-size: 1.1rem;
    }

    .pay-chip {
        background: rgba(16, 185, 129, 0.1);
        color: #10b981;
        padding: 8px 16px;
        border-radius: 12px;
        font-weight: 800;
        font-size: 0.95rem;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .ai-hr-box {
        background: #0F172A;
        color: #94A3B8;
        padding: 12px 18px;
        border-radius: 16px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        line-height: 1.4;
        border: 1px solid #1E293B;
        max-width: 320px;
    }

    .action-btn {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        border: 1px solid #e2e8f0;
        background: #fff;
        color: #64748b;
        text-decoration: none;
    }

    .action-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    .btn-edit:hover { color: #2563eb; border-color: #2563eb; }
    .btn-delete:hover { color: var(--eapro-red); border-color: var(--eapro-red); }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } }
</style>

<div class="payroll-container">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center mb-5 gap-3">
        <div>
            <h2 class="fw-800 text-dark mb-1">Personnel Matrix</h2>
            <p class="text-muted mb-0"><i class="fas fa-users-gear me-2 text-danger"></i>HR Oversight & Compensation Tracking</p>
        </div>
        
        <div class="d-flex flex-wrap gap-3">
            <a href="/Payroll/AttendanceLogs" class="btn btn-light border rounded-pill px-4 py-2 shadow-sm fw-bold">
                <i class="fas fa-clipboard-user text-primary me-2"></i>View Attendance
            </a>
            <a href="/Payroll/AttendanceKiosk" target="_blank" class="btn btn-dark rounded-pill px-4 py-2 shadow-lg fw-bold">
                <i class="fas fa-fingerprint me-2"></i>Launch Kiosk
            </a>
            <a href="/Payroll/Create" class="btn btn-danger rounded-pill px-4 py-2 shadow-lg fw-bold">
                <i class="fas fa-user-plus me-2"></i>Onboard Employee
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="matrix-card p-4 text-center">
                <small class="text-muted fw-bold d-block uppercase mb-1">Headcount</small>
                <h4 class="fw-800 mb-0">@Model.Count() Active Staff</h4>
            </div>
        </div>
        <div class="col-md-4">
            <div class="matrix-card p-4 text-center">
                <small class="text-muted fw-bold d-block uppercase mb-1">Monthly Outflow</small>
                @{ var totalOutflow = Model.Sum(x => x.BaseSalary + (x.Bonus ?? 0m)); }
                <h4 class="text-success fw-800 mb-0">₹@totalOutflow.ToString("N0")</h4>
            </div>
        </div>
    </div>

    <div class="matrix-card border-0">
        <div class="d-none d-lg-flex bg-dark text-white p-4 fw-bold small uppercase letter-spacing-1">
            <div style="width: 330px;">Employee Identity</div>
            <div style="width: 200px;">Designation</div>
            <div style="width: 200px;">Compensation</div>
            <div class="flex-grow-1">Neural HR Insight</div>
            <div style="width: 150px;" class="text-end">Management</div>
        </div>

        @foreach (var emp in Model) {
            <div class="employee-row d-flex flex-column flex-lg-row align-items-lg-center">
                <div class="d-flex align-items-center mb-3 mb-lg-0" style="width: 330px;">
                    <div class="emp-avatar me-3 shadow-sm flex-shrink-0">
                        @(string.IsNullOrEmpty(emp.Name) ? "?" : emp.Name.Substring(0, 1))
                    </div>
                    <div>
                        <span class="d-block fw-800 text-dark">@emp.Name</span>
                        <div class="d-flex align-items-center gap-2 mt-1">
                            <small class="text-muted">#EMP-@emp.Id.ToString("D4")</small>
                            <span class="text-muted" style="font-size: 0.7rem;">|</span>
                            <small class="text-danger fw-bold" style="font-size: 0.75rem;">
                                <i class="fas fa-barcode me-1"></i> @(string.IsNullOrEmpty(emp.EmployeeCode) ? "NO BARCODE" : emp.EmployeeCode)
                            </small>
                        </div>
                    </div>
                </div>

                <div class="mb-3 mb-lg-0" style="width: 200px;">
                    <span class="d-block fw-bold text-dark">@emp.Designation</span>
                    <span class="badge bg-light text-muted fw-bold" style="font-size: 0.65rem;">@emp.Department</span>
                </div>

                <div class="mb-3 mb-lg-0" style="width: 200px;">
                    @{ var currentPay = emp.BaseSalary + (emp.Bonus ?? 0m); }
                    <span class="pay-chip">
                        ₹@currentPay.ToString("N0")
                    </span>
                </div>

                <div class="flex-grow-1 mb-3 mb-lg-0">
                    <div class="ai-hr-box shadow-inner">
                        <i class="fas fa-brain text-danger me-2"></i>@emp.AIPerformanceInsight
                    </div>
                </div>

                <div style="width: 150px;" class="text-end">
                    <div class="d-flex justify-content-lg-end gap-2">
                        <a href="/Payroll/Details/@emp.Id" class="action-btn" title="View Dossier"><i class="fas fa-id-badge text-info"></i></a>
                        <a href="/Payroll/Edit/@emp.Id" class="action-btn btn-edit" title="Edit Profile"><i class="fas fa-user-pen"></i></a>
                        <a href="/Payroll/Delete/@emp.Id" class="action-btn btn-delete" title="Offboard"><i class="fas fa-user-minus"></i></a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>