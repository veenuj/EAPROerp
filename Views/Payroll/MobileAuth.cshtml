@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #0A0C12; color: white; font-family: sans-serif; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .auth-card { background: #161B22; padding: 2.5rem; border-radius: 30px; text-align: center; width: 90%; max-width: 400px; border: 1px solid rgba(211, 47, 47, 0.3); box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
        .btn-verify { background: #D32F2F; color: white; border: none; font-size: 1.2rem; font-weight: 800; padding: 1rem; border-radius: 100px; transition: 0.3s; width: 100%; }
        .btn-verify:active { transform: scale(0.95); background: #B71C1C; }
    </style>
</head>
<body>
    <div class="auth-card">
        <div id="authUI">
            <i class="fas fa-fingerprint text-danger mb-4" style="font-size: 5rem;"></i>
            <h2 class="fw-bold mb-2">EAPRO Identity</h2>
            <p class="text-white-50 mb-4">Confirm your identity to log attendance at the Roorkee Kiosk.</p>
            
            <input type="password" id="manualPin" class="form-control mb-4 text-center bg-dark text-white border-secondary py-3 fs-4" placeholder="ENTER ID CODE" inputmode="numeric">
            
            <button onclick="startMobileAuth()" id="mainBtn" class="btn-verify">
                <i class="fas fa-shield-halved me-2"></i>VERIFY & PUNCH
            </button>
        </div>

        <div id="status" class="mt-4 small fw-bold"></div>
    </div>

    <script>
        async function startMobileAuth() {
            const code = document.getElementById('manualPin').value;
            const status = document.getElementById('status');
            const token = "@ViewBag.Token";
            
            if(!code) {
                status.innerHTML = "<span class='text-warning'>Please enter your ID Code first</span>";
                return;
            }

            // Check for WebAuthn support
            if (window.PublicKeyCredential && window.PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable) {
                const available = await PublicKeyCredential.isUserVerifyingPlatformAuthenticatorAvailable();
                if (available) {
                    try {
                        // Triggers FaceID/TouchID prompt
                        await navigator.credentials.get({
                            publicKey: {
                                challenge: new Uint8Array([1, 2, 3, 4, 5, 6]),
                                userVerification: "required",
                                timeout: 60000
                            }
                        });
                    } catch (e) {
                        console.warn("Biometric verification skipped or failed:", e);
                        // We continue to the manual code verification if bio is cancelled
                    }
                }
            }

            // Final step: Inform the Kiosk via the server
            status.innerHTML = "<i class='fas fa-spinner fa-spin me-2'></i>Syncing with Kiosk...";
            
            try {
                const response = await fetch('/Payroll/VerifyMobile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `token=${token}&empCode=${code}`
                });

                if(response.ok) {
                    document.getElementById('authUI').innerHTML = `
                        <div class="py-4">
                            <i class="fas fa-circle-check text-success mb-3" style="font-size: 5rem;"></i>
                            <h2 class="text-success">Verified!</h2>
                            <p class="text-white-50">Kiosk is processing your attendance. You can close this window.</p>
                        </div>`;
                    status.innerHTML = "";
                }
            } catch (err) {
                status.innerHTML = "<span class='text-danger'>Connection Error. Is your Wi-Fi on?</span>";
            }
        }
    </script>
</body>
</html>