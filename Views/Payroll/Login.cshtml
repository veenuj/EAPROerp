@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #0F172A; height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Inter', sans-serif; }
        .login-card { background: white; padding: 3rem; border-radius: 30px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); width: 100%; max-width: 450px; text-align: center; }
        .vault-icon { width: 80px; height: 80px; background: #FEE2E2; color: #DC2626; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1.5rem; }
        .btn-access { background: #0F172A; color: white; border-radius: 12px; padding: 12px; font-weight: 700; width: 100%; transition: 0.3s; border: none; }
        .btn-access:hover { background: #1E293B; transform: translateY(-2px); }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="vault-icon"><i class="fas fa-shield-halved"></i></div>
        <h3 class="fw-800 text-dark">Payroll Vault</h3>
        <p class="text-muted mb-4">Authorized Personnel Only</p>

        @if (TempData["Error"] != null) {
            <div class="alert alert-danger py-2 small">@TempData["Error"]</div>
        }

        <form asp-action="Login" method="post">
            <div class="mb-3 text-start">
                <label class="small fw-bold text-muted ms-1">Security Key</label>
                <input type="password" name="password" class="form-control form-control-lg rounded-3" placeholder="••••••••" required autofocus>
            </div>
            <button type="submit" class="btn-access mt-2">Unlock Module</button>
        </form>
        
        <p class="mt-4 small text-muted">EAPRO GLOBAL LTD. &copy; 2026</p>
    </div>
</body>
</html>