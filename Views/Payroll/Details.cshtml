@model EaproERP.Models.Employee
@{ 
    ViewData["Title"] = "Employee Dossier"; 
    
    // 🛑 BULLETPROOF MATH BLOCK: Calculates safely before rendering HTML 🛑
    decimal safeBonus = Model.Bonus ?? 0m;
    decimal safeTotalPay = Model.BaseSalary + safeBonus;
}

<style>
    .dossier-card { border-radius: 24px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.05); overflow: hidden; background: #fff; }
    .dossier-header { background: linear-gradient(135deg, #0F111A 0%, #1c253b 100%); color: white; padding: 2.5rem; position: relative; border-bottom: 3px solid var(--eapro-red); }
    .dossier-header::after { content: ''; position: absolute; right: 0; top: -50px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(211,47,47,0.3) 0%, transparent 70%); border-radius: 50%; }
    
    .info-label { font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #94A3B8; letter-spacing: 0.5px; margin-bottom: 0.25rem; }
    .info-value { font-size: 1.1rem; font-weight: 700; color: #1E293B; margin-bottom: 1.5rem; }
    
    .barcode-badge { background: rgba(255,255,255,0.1); padding: 8px 16px; border-radius: 12px; font-family: monospace; font-size: 1.2rem; letter-spacing: 2px; border: 1px dashed rgba(255,255,255,0.3); }
    .ai-insight-panel { background: #0F172A; color: #94A3B8; border-radius: 16px; padding: 1.5rem; font-family: 'JetBrains Mono', monospace; border-left: 4px solid var(--eapro-red); font-size: 0.9rem; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-800 text-dark mb-0">Personnel Dossier</h2>
    <div>
        <a href="/Payroll/Edit/@Model.Id" class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm me-2"><i class="fas fa-pen me-2"></i>Edit Record</a>
        <a href="/Payroll" class="btn btn-light rounded-pill px-4 fw-bold border"><i class="fas fa-arrow-left me-2"></i>Back to Matrix</a>
    </div>
</div>

<div class="dossier-card">
    <div class="dossier-header d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-4 position-relative" style="z-index: 2;">
            <div class="bg-danger rounded-4 d-flex align-items-center justify-content-center shadow-lg" style="width: 80px; height: 80px; font-size: 2.5rem; font-weight: 800;">
                @(string.IsNullOrEmpty(Model.Name) ? "?" : Model.Name.Substring(0, 1))
            </div>
            <div>
                <h2 class="fw-800 mb-1">@Model.Name</h2>
                <h6 class="text-white-50 fw-bold mb-0">@Model.Designation • <span class="badge bg-light text-dark ms-1">@Model.Department</span></h6>
            </div>
        </div>
        <div class="text-end position-relative" style="z-index: 2;">
            <span class="d-block text-white-50 small fw-bold uppercase mb-1">Scanner ID</span>
            <div class="barcode-badge">
                <i class="fas fa-barcode me-2 text-danger"></i>@(string.IsNullOrEmpty(Model.EmployeeCode) ? "UNASSIGNED" : Model.EmployeeCode)
            </div>
        </div>
    </div>

    <div class="card-body p-5">
        <div class="row">
            <div class="col-lg-7 border-end pe-lg-5">
                <h5 class="fw-800 text-danger mb-4"><i class="fas fa-address-card me-2"></i>Identity & Contact</h5>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-label">Date of Joining</div>
                        <div class="info-value">@Model.DateOfJoining.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">Phone Number</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">Emergency Contact</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.EmergencyContact) ? "N/A" : Model.EmergencyContact)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">Gov ID (Aadhar/PAN)</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.GovernmentId) ? "N/A" : Model.GovernmentId)</div>
                    </div>
                </div>

                <h5 class="fw-800 text-danger mt-4 mb-4"><i class="fas fa-building-columns me-2"></i>Banking Details</h5>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-label">Account Number</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.BankAccountNumber) ? "N/A" : Model.BankAccountNumber)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-label">IFSC Code</div>
                        <div class="info-value">@(string.IsNullOrEmpty(Model.IFSCCode) ? "N/A" : Model.IFSCCode)</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 ps-lg-5 mt-5 mt-lg-0">
                <h5 class="fw-800 text-danger mb-4"><i class="fas fa-wallet me-2"></i>Compensation Overview</h5>
                
                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted fw-bold">Base Salary</span>
                    <span class="fw-800 text-dark">₹@Model.BaseSalary.ToString("N0")</span>
                </div>
                
                <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                    <span class="text-muted fw-bold">Performance Bonus</span>
                    <span class="fw-800 text-dark">₹@safeBonus.ToString("N0")</span>
                </div>
                
                <div class="d-flex justify-content-between mb-4 bg-light p-3 rounded-3 border">
                    <span class="text-muted fw-800 uppercase">Monthly Total</span>
                    <span class="fw-800 text-success fs-4">₹@safeTotalPay.ToString("N0")</span>
                </div>

                <div class="ai-insight-panel shadow-sm mt-4">
                    <div class="text-white fw-bold mb-2"><i class="fas fa-robot text-danger me-2"></i>Neural HR Analysis</div>
                    @Model.AIPerformanceInsight
                </div>
            </div>
        </div>
    </div>
</div>