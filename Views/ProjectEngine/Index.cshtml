@model IEnumerable<EaproERP.Models.ProjectEngine>
@{ ViewData["Title"] = "Project Engine"; }

<style>
    :root { --eapro-red: #D32F2F; --border-subtle: rgba(255,255,255,0.08); }
    .project-wrapper { animation: fadeIn 0.5s ease-out; }

    /* Stats Ribbon */
    .metric-ribbon { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 2.5rem; }
    .m-card { background: #0F111A; border: 1px solid var(--border-subtle); border-radius: 16px; padding: 1.25rem; }
    .m-label { font-size: 0.6rem; font-weight: 800; color: #64748B; text-transform: uppercase; letter-spacing: 1.5px; }
    .m-value { font-size: 1.2rem; font-weight: 700; color: #fff; display: block; margin-top: 5px; }

    /* Project Ledger */
    .project-card { 
        background: #0F111A; border: 1px solid var(--border-subtle); border-radius: 20px; 
        padding: 1.5rem; margin-bottom: 1rem; transition: 0.3s;
    }
    .project-card:hover { border-color: var(--eapro-red); transform: translateX(5px); }

    .progress-track { height: 6px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; width: 150px; }
    .progress-fill { height: 100%; background: var(--eapro-red); box-shadow: 0 0 10px var(--eapro-red); }

    .phase-badge { 
        font-size: 0.65rem; font-weight: 800; padding: 5px 12px; border-radius: 6px; 
        text-transform: uppercase; background: rgba(255,255,255,0.05); color: #94A3B8;
    }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } }
</style>

<div class="project-wrapper">
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom border-white border-opacity-5 pb-4">
        <div>
            <div class="text-danger fw-800 small mb-2 uppercase letter-spacing-2">EPC & Deployment Node</div>
            <h1 class="fw-800 text-white mb-0" style="letter-spacing: -2px;">Project <span class="text-danger">Engine</span></h1>
        </div>
        <a asp-action="Create" class="btn btn-danger rounded-pill px-4 fw-800 shadow-lg">INITIALIZE_PROJECT</a>
    </div>

    <div class="metric-ribbon">
        <div class="m-card">
            <span class="m-label">Active Deployments</span>
            <span class="m-value">@Model.Count() Projects</span>
        </div>
        <div class="m-card">
            <span class="m-label">Total Load</span>
            <span class="m-value">@Model.Sum(x => x.SystemCapacityKW) <small class="text-white-50">kWp</small></span>
        </div>
        <div class="m-card">
            <span class="m-label">Commissioning Rate</span>
            <span class="m-value text-success">84%</span>
        </div>
        <div class="m-card" style="border-left: 3px solid var(--eapro-red);">
            <span class="m-label text-danger">Pending Surveys</span>
            <span class="m-value">02 Units</span>
        </div>
    </div>

    @foreach (var p in Model) {
        <div class="project-card d-flex align-items-center justify-content-between">
            <div style="width: 300px;">
                <h5 class="fw-800 text-white mb-1">@p.ProjectName</h5>
                <div class="d-flex align-items-center gap-2">
                    <span class="phase-badge">@p.CurrentPhase</span>
                    <small class="text-muted fw-bold">@p.SiteLocation</small>
                </div>
            </div>

            <div class="text-center">
                <span class="m-label d-block mb-1">System Capacity</span>
                <span class="fw-800 text-white">@p.SystemCapacityKW <small class="text-white-50">kWp</small></span>
            </div>

            <div style="width: 200px;">
                <span class="m-label d-block mb-1">Execution (@p.ExecutionProgress%)</span>
                <div class="progress-track"><div class="progress-fill" style="width: @p.ExecutionProgress%"></div></div>
            </div>

            <div class="text-end">
                <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-dark border border-white border-opacity-10 rounded-3 px-3 fw-bold">VIEW_DOSSIER</a>
            </div>
        </div>
    }
</div>