@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>TITAN // Security Gate</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #0A0C12; height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; color: white; }
        .lock-card { background: #111827; border: 1px solid rgba(255,255,255,0.1); padding: 3rem; border-radius: 32px; width: 450px; text-align: center; }
        .pin-input { background: #1F2937; border: 2px solid #374151; color: #fff; text-align: center; font-size: 1.5rem; letter-spacing: 10px; border-radius: 16px; margin-bottom: 20px; }
        .pin-input:disabled { opacity: 0.5; cursor: not-allowed; border-color: #D32F2F; }
        .timer-display { font-family: 'JetBrains Mono', monospace; color: #D32F2F; font-size: 1.2rem; font-weight: 800; }
        .error-msg { color: #f87171; font-size: 0.8rem; font-weight: 600; margin-bottom: 15px; }
    </style>
</head>
<body>
    <div class="lock-card shadow-lg">
        <div class="mb-4">
            <div class="bg-danger d-inline-block p-3 rounded-circle shadow-lg mb-3">
                <i class="fas @(ViewBag.LockoutExpiry != null ? "fa-user-lock" : "fa-shield-halved") text-white fs-3"></i>
            </div>
            <h4 class="fw-800">Financial Vault</h4>
            
            @if (ViewBag.LockoutExpiry != null) {
                <p class="text-danger small fw-bold">SYSTEM LOCKED DUE TO MULTIPLE FAILURES</p>
                @* We store the expiry date in a data attribute here *@
                <div class="timer-display mb-3" id="countdown" data-expiry="@ViewBag.LockoutExpiry">Calculating...</div>
            } else {
                <p class="text-muted small">Enter Authorization PIN to Access Ledger</p>
            }
        </div>

        @if (ViewBag.ErrorMessage != null) {
            <div class="error-msg">@ViewBag.ErrorMessage</div>
        }

        <form asp-action="PaymentSummary" method="get">
            <input type="password" name="pin" class="form-control pin-input" maxlength="4" autofocus required 
                   placeholder="****" @(ViewBag.LockoutExpiry != null ? "disabled" : "") />
            
            <button type="submit" class="btn btn-danger w-100 py-3 rounded-pill fw-800" @(ViewBag.LockoutExpiry != null ? "disabled" : "")>
                @(ViewBag.LockoutExpiry != null ? "ACCESS_RESTRICTED" : "UNLOCK_LEDGER")
            </button>
        </form>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const timerElement = document.getElementById('countdown');
            if (!timerElement) return;

            const expiryStr = timerElement.getAttribute('data-expiry');
            if (!expiryStr) return;

            const expiry = new Date(expiryStr).getTime();

            const x = setInterval(function() {
                const now = new Date().getTime();
                const distance = expiry - now;

                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                timerElement.innerHTML = minutes + "m " + seconds + "s ";

                if (distance < 0) {
                    clearInterval(x);
                    window.location.href = window.location.pathname; 
                }
            }, 1000);
        });
    </script>
</body>
</html>