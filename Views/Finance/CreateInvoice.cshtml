@model EaproERP.Models.Invoice
@{ ViewData["Title"] = "Neural Billing Engine"; }

<style>
    :root {
        --titan-red: #D32F2F;
        --titan-dark: #0F172A;
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    .billing-wrapper { animation: slideIn 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    
    .billing-card { 
        background: var(--glass-bg); 
        backdrop-filter: blur(10px);
        border: 1px solid #E2E8F0; 
        border-radius: 32px; 
        padding: 4rem; 
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.08); 
    }

    /* --- Premium Mode Toggle --- */
    .mode-switch-container {
        background: #F1F5F9;
        padding: 6px;
        border-radius: 100px;
        display: inline-flex;
        border: 1px solid #E2E8F0;
    }

    .mode-btn {
        border: none;
        padding: 10px 28px;
        border-radius: 100px;
        font-weight: 800;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        color: #64748B;
        background: transparent;
    }

    .mode-btn.btn-active {
        background: var(--titan-red);
        color: #fff;
        box-shadow: 0 10px 20px rgba(211, 47, 47, 0.3);
    }

    /* --- Modern Form Inputs --- */
    .form-group-custom { position: relative; margin-bottom: 1.5rem; }
    
    .input-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: #94A3B8;
        font-size: 1rem;
        transition: 0.3s;
    }

    .premium-input {
        width: 100%;
        padding: 18px 20px 18px 55px;
        background: #F8FAFC;
        border: 2px solid #F1F5F9;
        border-radius: 18px;
        font-weight: 600;
        transition: 0.3s;
        color: var(--titan-dark);
    }

    .premium-input:focus {
        background: #fff;
        border-color: var(--titan-red);
        outline: none;
        box-shadow: 0 0 0 4px rgba(211, 47, 47, 0.1);
    }

    .premium-input:focus + .input-icon { color: var(--titan-red); }

    /* --- Dynamic Tax Panel --- */
    .ledger-panel {
        background: var(--titan-dark);
        border-radius: 24px;
        padding: 30px;
        color: #fff;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: 0 20px 40px rgba(15, 23, 42, 0.2);
    }

    .ledger-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-size: 0.85rem;
        font-weight: 500;
        color: #94A3B8;
    }

    .ledger-row.total {
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.1);
        color: #fff;
    }

    .currency-symbol { color: var(--titan-red); font-weight: 800; margin-right: 4px; }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>



<div class="container py-5 billing-wrapper">
    <div class="billing-card">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="badge bg-danger-subtle text-danger mb-2 px-3 py-2 rounded-pill fw-800" style="font-size: 0.6rem; letter-spacing: 1px;">FINANCIAL_NODE // v5.0</span>
                <h1 class="fw-800 text-dark mb-0" style="letter-spacing: -1.5px;">Create <span class="text-danger">Invoice</span></h1>
            </div>
            
            <div class="mode-switch-container">
                <button type="button" id="btnNonGst" class="mode-btn btn-active" onclick="toggleGst(false)">
                    <i class="fas fa-tag me-2"></i>COMMERCIAL
                </button>
                <button type="button" id="btnGst" class="mode-btn" onclick="toggleGst(true)">
                    <i class="fas fa-percent me-2"></i>GST_MODE
                </button>
            </div>
        </div>

        <form asp-action="GenerateInvoice">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="IsGstInvoice" id="isGstInput" value="false" />
            
            <div class="row g-5">
                <div class="col-lg-7">
                    <div class="form-group-custom">
                        <label class="fw-800 small text-muted uppercase mb-2 d-block ms-2">Client Identity</label>
                        <input asp-for="CustomerName" class="premium-input" placeholder="Search or Enter Customer Name" required />
                        <i class="fas fa-user-tie input-icon"></i>
                    </div>

                    <div id="gstField" class="form-group-custom" style="display:none; transition: 0.4s;">
                        <label class="fw-800 small text-muted uppercase mb-2 d-block ms-2">Customer GSTIN</label>
                        <input asp-for="CustomerGSTIN" class="premium-input" placeholder="22AAAAA0000A1Z5" maxlength="15" />
                        <i class="fas fa-fingerprint input-icon"></i>
                    </div>

                    <div class="form-group-custom">
                        <label class="fw-800 small text-muted uppercase mb-2 d-block ms-2">Transaction Value (Base Amount)</label>
                        <input asp-for="BaseAmount" id="baseAmt" type="number" step="0.01" class="premium-input" placeholder="0.00" oninput="calculateTotal()" required />
                        <i class="fas fa-indian-rupee-sign input-icon"></i>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="ledger-panel">
                        <h6 class="text-white fw-800 mb-4 uppercase small" style="letter-spacing: 2px;">Calculation Summary</h6>
                        
                        <div class="ledger-row">
                            <span>Taxable Subtotal</span>
                            <span><span class="currency-symbol">₹</span><span id="displayBase">0.00</span></span>
                        </div>

                        <div class="ledger-row" id="taxRow" style="display:none !important;">
                            <span>Output GST (18%)</span>
                            <span class="text-danger fw-bold">+ ₹<span id="displayTax">0.00</span></span>
                        </div>

                        <div class="ledger-row total">
                            <span class="h6 fw-800 mb-0">Total Payable</span>
                            <span class="h4 fw-800 mb-0">₹<span id="displayTotal">0.00</span></span>
                        </div>

                        <p class="text-muted mt-4 mb-0" style="font-size: 0.65rem; font-style: italic;">
                            * Taxes calculated based on Roorkee Manufacturing Unit protocols.
                        </p>
                    </div>
                </div>
            </div>

            <div class="mt-5 d-flex justify-content-between align-items-center">
                <a href="/Finance/InvoiceList" class="text-muted fw-bold text-decoration-none small">
                    <i class="fas fa-arrow-left me-2"></i> Return to Vault
                </a>
                <button type="submit" class="btn btn-dark rounded-pill px-5 py-3 fw-800 shadow-lg">
                    Authorize & Generate Invoice <i class="fas fa-cloud-arrow-up ms-2"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleGst(isGst) {
        document.getElementById('isGstInput').value = isGst;
        const gstField = document.getElementById('gstField');
        const taxRow = document.getElementById('taxRow');
        
        if(isGst) {
            gstField.style.display = 'block';
            taxRow.style.setProperty('display', 'flex', 'important');
        } else {
            gstField.style.display = 'none';
            taxRow.style.setProperty('display', 'none', 'important');
        }
        
        // Update Buttons
        document.getElementById('btnGst').classList.toggle('btn-active', isGst);
        document.getElementById('btnNonGst').classList.toggle('btn-active', !isGst);
        
        calculateTotal();
    }

    function calculateTotal() {
        const base = parseFloat(document.getElementById('baseAmt').value) || 0;
        const isGst = document.getElementById('isGstInput').value === 'true';
        const tax = isGst ? (base * 0.18) : 0;
        const total = base + tax;

        document.getElementById('displayBase').innerText = base.toLocaleString('en-IN', { minimumFractionDigits: 2 });
        document.getElementById('displayTax').innerText = tax.toLocaleString('en-IN', { minimumFractionDigits: 2 });
        document.getElementById('displayTotal').innerText = total.toLocaleString('en-IN', { minimumFractionDigits: 2 });
    }
</script>