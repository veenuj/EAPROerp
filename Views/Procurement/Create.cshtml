@model EaproERP.Models.Vendor
@{ ViewData["Title"] = (Model?.Id > 0 ? "Modify" : "Initialize") + " Vendor"; }

<style>
    .form-card { background: #fff; border-radius: 30px; box-shadow: 0 40px 100px rgba(0,0,0,0.06); padding: 4rem; max-width: 900px; margin: 2rem auto; }
    .input-group-custom { margin-bottom: 1.5rem; }
    .label-tech { font-size: 0.7rem; font-weight: 800; color: #94A3B8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; display: block; }
    .form-control-titan { background: #F8FAFC; border: 1px solid #E2E8F0; border-radius: 12px; padding: 12px 18px; font-weight: 600; }
    .form-control-titan:focus { border-color: #D32F2F; box-shadow: 0 0 0 4px rgba(211,47,47,0.1); }
</style>

<div class="form-card">
    <div class="mb-5 text-center">
        <h2 class="fw-800 text-dark">@(Model?.Id > 0 ? "Update Vendor Logic" : "Initialize New Supplier")</h2>
        <p class="text-muted">Registering strategic procurement node for EAPRO ecosystem</p>
    </div>

    <form asp-action="@(Model?.Id > 0 ? "Edit" : "Create")" method="post">
        @if (Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }
        
        <div class="row g-4">
            <div class="col-md-7">
                <label class="label-tech">Registered Company Name</label>
                <input asp-for="CompanyName" class="form-control-titan w-100" required />
            </div>
            <div class="col-md-5">
                <label class="label-tech">Supplier Category</label>
                <select asp-for="Category" class="form-select form-control-titan">
                    <option value="Raw Materials">Raw Materials</option>
                    <option value="Electronics">Electronics (PCU/DSP)</option>
                    <option value="Logistics">Logistics Hub</option>
                    <option value="Energy Storage">Battery Cells</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="label-tech">Primary Contact</label>
                <input asp-for="ContactPerson" class="form-control-titan w-100" />
            </div>
            <div class="col-md-6">
                <label class="label-tech">System Reliability (1-100)</label>
                <input asp-for="ReliabilityScore" type="number" class="form-control-titan w-100" />
            </div>
            <div class="col-md-12">
                <label class="label-tech">Secure Email Address</label>
                <input asp-for="Email" type="email" class="form-control-titan w-100" />
            </div>
            <div class="col-md-6">
                <label class="label-tech">Opening Liability (INR)</label>
                <input asp-for="OutstandingBalance" type="number" step="0.01" class="form-control-titan w-100 text-danger fw-bold" />
            </div>
            <div class="col-md-6">
                <label class="label-tech">Operational Status</label>
                <select asp-for="Status" class="form-select form-control-titan">
                    <option value="Active">Active_Uplink</option>
                    <option value="Under Review">Under_Review</option>
                    <option value="Blacklisted">Terminated</option>
                </select>
            </div>
        </div>

        <div class="mt-5 pt-4 border-top d-flex justify-content-between align-items-center">
            <a href="/Procurement" class="text-muted text-decoration-none fw-bold small">ABORT_OPERATION</a>
            <button type="submit" class="btn btn-danger rounded-pill px-5 py-2 fw-800 shadow-lg">SYNC TO NEURAL CORE</button>
        </div>
    </form>
</div>