@model EaproERP.Models.Vendor
@{ ViewData["Title"] = "Vendor Dossier"; }

<style>
    :root { --eapro-red: #D32F2F; --glass: rgba(255, 255, 255, 0.03); }
    .dossier-wrapper { animation: fadeIn 0.6s ease-out; max-width: 1100px; margin: 0 auto; }
    
    .dossier-header {
        background: linear-gradient(135deg, #0A0C12 0%, #1a1a1a 100%);
        border-radius: 30px; padding: 3rem; color: white;
        border: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem;
        position: relative; overflow: hidden;
    }

    .spec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 2rem; }
    .spec-box { background: var(--glass); border: 1px solid rgba(255,255,255,0.05); border-radius: 20px; padding: 1.5rem; }
    .label { font-size: 0.65rem; font-weight: 800; color: #94A3B8; text-transform: uppercase; letter-spacing: 1.5px; display: block; margin-bottom: 5px; }
    .value { font-size: 1.1rem; font-weight: 700; color: #fff; }

    .reliability-gauge { height: 8px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden; margin-top: 10px; }
    .gauge-fill { height: 100%; background: #00E676; box-shadow: 0 0 10px #00E676; }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="dossier-wrapper py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <a href="/Procurement" class="text-white-50 text-decoration-none fw-bold small uppercase"><i class="fas fa-chevron-left me-2"></i> Vendor Matrix</a>
        <div class="d-flex gap-2">
            <a href="/Procurement/Edit/@Model.Id" class="btn btn-danger rounded-pill px-4 fw-800">EDIT CONTRACT</a>
        </div>
    </div>

    <div class="dossier-header shadow-lg">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="badge bg-danger rounded-pill px-3 py-2 fw-800 small mb-3">VERIFIED_SUPPLIER_NODE</span>
                <h1 class="fw-800 display-4 mb-2">@Model.CompanyName</h1>
                <div class="text-white-50 font-monospace small">UPLINK_STATUS: <span class="text-success">STABLE</span></div>
            </div>
            <div class="col-md-4 text-end">
                <i class="fas fa-truck-fast text-white opacity-10" style="font-size: 7rem;"></i>
            </div>
        </div>
    </div>

    <div class="spec-grid">
        <div class="spec-box">
            <span class="label">Financial Exposure</span>
            <span class="value text-danger">₹@Model.OutstandingBalance.ToString("N0")</span>
        </div>
        <div class="spec-box">
            <span class="label">Hardware Category</span>
            <span class="value">@Model.Category</span>
        </div>
        <div class="spec-box">
            <span class="label">Reliability Index</span>
            <span class="value">@Model.ReliabilityScore%</span>
            <div class="reliability-gauge"><div class="gauge-fill" style="width: @Model.ReliabilityScore%"></div></div>
        </div>
    </div>

    <div class="bg-white bg-opacity-5 border border-white border-opacity-5 rounded-4 p-4">
        <h6 class="fw-800 text-white-50 uppercase mb-4 letter-spacing-1">Point of Contact</h6>
        <div class="row">
            <div class="col-md-6 mb-3">
                <small class="text-muted d-block fw-bold uppercase" style="font-size: 0.6rem;">Liaison Name</small>
                <span class="fw-bold">@Model.ContactPerson</span>
            </div>
            <div class="col-md-6">
                <small class="text-muted d-block fw-bold uppercase" style="font-size: 0.6rem;">Comm Link</small>
                <span class="fw-bold text-info">@Model.Email</span>
            </div>
        </div>
    </div>
</div>