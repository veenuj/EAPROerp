@model EaproERP.Models.Dealer
@{ ViewData["Title"] = "Partner Portfolio"; }

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --eapro-dark: #0A0C12;
        /* Tier Colors */
        --platinum: linear-gradient(135deg, #94A3B8 0%, #475569 100%);
        --gold: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
        --silver: linear-gradient(135deg, #CBD5E1 0%, #94A3B8 100%);
    }

    .portfolio-container { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Left Identity Card */
    .identity-sidebar {
        background: linear-gradient(180deg, var(--eapro-dark) 0%, #161B22 100%);
        border-radius: 35px 0 0 35px;
        position: relative;
        overflow: hidden;
    }
    .identity-sidebar::before {
        content: ""; position: absolute; top: -50px; left: -50px;
        width: 200px; height: 200px;
        background: var(--eapro-red);
        filter: blur(120px); opacity: 0.15;
    }

    /* Main Info Card */
    .portfolio-card {
        background: white;
        border-radius: 35px;
        box-shadow: 0 40px 80px rgba(0,0,0,0.08);
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    /* Tier-specific Badge logic */
    .tier-indicator {
        font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
        letter-spacing: 1.5px; padding: 8px 20px; border-radius: 100px;
        color: white; display: inline-block;
        background: @(Model.Tier == "Platinum" ? "var(--platinum)" : Model.Tier == "Gold" ? "var(--gold)" : "var(--silver)");
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .info-label { font-size: 0.7rem; font-weight: 800; color: #94A3B8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
    .info-value { font-size: 1.1rem; font-weight: 700; color: var(--eapro-slate); }

    /* AI Intelligence Briefing */
    .ai-briefing {
        background: #F8FAFC;
        border-radius: 24px;
        border-left: 5px solid var(--eapro-red);
        padding: 2rem;
        position: relative;
    }
    .ai-briefing::after {
        content: "\f085"; font-family: "Font Awesome 6 Free"; font-weight: 900;
        position: absolute; right: 20px; top: 20px; font-size: 4rem;
        color: var(--eapro-red); opacity: 0.03;
    }

    .stat-box {
        background: #fff;
        border: 1px solid #edf2f7;
        border-radius: 20px;
        padding: 1.5rem;
        transition: 0.3s;
    }
    .stat-box:hover { transform: translateY(-5px); border-color: var(--eapro-red); }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container portfolio-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-11">
            
            <div class="portfolio-card">
                <div class="row g-0">
                    <div class="col-lg-4 identity-sidebar p-5 text-center text-white d-flex flex-column justify-content-center">
                        <div class="mb-4">
                            <div class="bg-danger d-inline-flex align-items-center justify-content-center rounded-4 shadow-lg mb-4" style="width: 100px; height: 100px;">
                                <i class="fas fa-handshake fs-1"></i>
                            </div>
                            <h2 class="fw-800 mb-2">@Model.BusinessName</h2>
                            <div class="tier-indicator">@Model.Tier Partner</div>
                        </div>
                        
                        <div class="mt-4 pt-4 border-top border-secondary border-opacity-25">
                            <p class="text-white-50 small fw-bold uppercase letter-spacing-1">Network Region</p>
                            <h5 class="fw-700"><i class="fas fa-map-location-dot me-2 text-danger"></i>@Model.Region India</h5>
                        </div>

                        <div class="mt-auto pt-5">
                            <a asp-action="Index" class="text-white-50 text-decoration-none small fw-800 uppercase">
                                <i class="fas fa-chevron-left me-2"></i>Back to Network
                            </a>
                        </div>
                    </div>

                    <div class="col-lg-8 p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-start mb-5">
                            <div>
                                <h3 class="fw-800 text-dark mb-1">Partner Portfolio</h3>
                                <p class="text-muted fw-500">Comprehensive Business Metrics & History</p>
                            </div>
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark rounded-pill px-4 py-2 fw-bold shadow">
                                <i class="fas fa-user-pen me-2"></i>Modify Profile
                            </a>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-sm-6">
                                <div class="stat-box">
                                    <div class="info-label">Primary Stakeholder</div>
                                    <div class="info-value">@Model.ContactPerson</div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="stat-box">
                                    <div class="info-label">Current Status</div>
                                    <div class="info-value text-success"><i class="fas fa-circle-check me-2"></i>Operational</div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="stat-box">
                                    <div class="info-label">Support Infrastructure</div>
                                    <div class="info-value">
                                        @if(Model.IsServiceCenter) {
                                            <span class="text-danger"><i class="fas fa-tools me-2"></i>Authorized Center</span>
                                        } else {
                                            <span><i class="fas fa-store me-2"></i>Sales Outlet</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="stat-box">
                                    <div class="info-label">Annual Volume</div>
                                    <div class="info-value text-dark">₹@Model.AnnualTurnover.ToString("N0")</div>
                                </div>
                            </div>
                        </div>

                        <div class="ai-briefing shadow-sm">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="bg-danger text-white rounded-3 p-2 shadow-sm">
                                    <i class="fas fa-brain"></i>
                                </div>
                                <h6 class="fw-800 text-dark mb-0 uppercase letter-spacing-1">Neural Intelligence Briefing</h6>
                            </div>
                            <p class="text-secondary leading-relaxed mb-0">
                                @EaproERP.Agents.AiEngine.RunDealerAgent(Model)
                            </p>
                        </div>

                        <div class="mt-5 text-end text-muted">
                            <small class="fw-bold uppercase" style="font-size: 0.6rem;">Last Synchronized: @DateTime.Now.ToString("dd MMM yyyy")</small>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>