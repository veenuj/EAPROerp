@model EaproERP.Models.Dealer
@{ ViewData["Title"] = "Remove Partner"; }

<div class="row justify-content-center text-center">
    <div class="col-md-6 mt-5">
        <div class="bg-white p-5 rounded-5 shadow-lg border border-danger border-opacity-10">
            <div class="text-danger mb-4">
                <i class="fas fa-exclamation-triangle fa-5x"></i>
            </div>
            <h3 class="fw-bold">Confirm Removal</h3>
            <p class="text-muted">Are you sure you want to remove <strong>@Model.BusinessName</strong> from the EAPRO Dealer Network? This action is permanent.</p>
            
            <form asp-action="Delete" class="mt-5">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 me-2 shadow">Delete Partner</button>
                <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-5">Cancel</a>
            </form>
        </div>
    </div>
</div>