@model IEnumerable<EaproERP.Models.Dealer>
@{
    ViewData["Title"] = "Partner Matrix";
    var totalVolume = Model.Sum(x => x.AnnualTurnover);
    var platinumCount = Model.Count(x => x.Tier == "Platinum");
    var goldCount = Model.Count(x => x.Tier == "Gold");
}

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --platinum-gradient: linear-gradient(135deg, #3b82f6, #2563eb);
        --gold-gradient: linear-gradient(135deg, #f59e0b, #d97706);
        --silver-gradient: linear-gradient(135deg, #94a3b8, #64748b);
    }

    .matrix-container { animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Header Stat Cards */
    .stat-pill {
        background: white;
        border-radius: 20px;
        padding: 1rem 1.5rem;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* Partner Card Design */
    .partner-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid #edf2f7;
        border-radius: 35px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }

    .partner-card:hover {
        transform: translateY(-12px);
        box-shadow: 0 30px 60px rgba(15, 23, 42, 0.1);
        border-color: var(--eapro-red);
    }

    /* Visual Indicator for Tiers */
    .tier-ribbon {
        height: 8px;
        width: 100%;
        position: absolute;
        top: 0; left: 0;
    }
    .ribbon-Platinum { background: var(--platinum-gradient); }
    .ribbon-Gold { background: var(--gold-gradient); }
    .ribbon-Silver { background: var(--silver-gradient); }

    .tier-tag {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 6px 14px;
        border-radius: 100px;
        color: white;
    }

    .hub-active {
        background: #dcfce7;
        color: #15803d;
        font-size: 0.7rem;
        font-weight: 800;
        padding: 6px 14px;
        border-radius: 100px;
    }

    /* Data Visualization Box */
    .metric-grid {
        background: #f8fafc;
        border-radius: 24px;
        padding: 1.25rem;
        border: 1px solid #f1f5f9;
    }

    /* Neural Insight Box */
    .neural-readout {
        background: #0F172A;
        border-radius: 20px;
        padding: 15px;
        color: #94A3B8;
        font-family: 'Outfit', sans-serif;
        font-size: 0.8rem;
        border-left: 4px solid var(--eapro-red);
        line-height: 1.4;
    }

    /* Action Buttons */
    .btn-action-circle {
        width: 44px; height: 44px;
        border-radius: 15px;
        display: flex; align-items: center; justify-content: center;
        background: white; border: 1px solid #e2e8f0;
        color: #64748b; transition: 0.3s;
    }
    .btn-action-circle:hover { background: var(--eapro-red); color: white; border-color: var(--eapro-red); transform: rotate(15deg); }

    @@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="matrix-container py-4">
    <div class="row align-items-center mb-5 g-4">
        <div class="col-lg-5">
            <h1 class="fw-800 text-dark mb-1">Partner <span class="text-danger">Matrix</span></h1>
            <p class="text-muted fw-500">Managing EAPRO's High-Value Commercial Network</p>
        </div>
        <div class="col-lg-7">
            <div class="d-flex flex-wrap gap-3 justify-content-lg-end">
                <div class="stat-pill">
                    <div class="bg-success bg-opacity-10 text-success p-2 rounded-3"><i class="fas fa-chart-line"></i></div>
                    <div>
                        <div class="text-muted small fw-800 uppercase" style="font-size: 0.6rem;">Network Volume</div>
                        <div class="fw-800 text-dark">₹@totalVolume.ToString("N0")</div>
                    </div>
                </div>
                <div class="stat-pill">
                    <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3"><i class="fas fa-crown"></i></div>
                    <div>
                        <div class="text-muted small fw-800 uppercase" style="font-size: 0.6rem;">Platinum Tier</div>
                        <div class="fw-800 text-dark">@platinumCount Units</div>
                    </div>
                </div>
                <a asp-action="Create" class="btn btn-danger rounded-pill px-4 fw-800 d-flex align-items-center shadow-lg border-0">
                    <i class="fas fa-plus-circle me-2"></i> Register Partner
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var item in Model) {
            <div class="col-md-6 col-xl-4">
                <div class="partner-card h-100">
                    <div class="tier-ribbon ribbon-@item.Tier"></div>

                    <div class="card-body p-4 pt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="tier-tag ribbon-@item.Tier">@item.Tier Level</span>
                            @if(item.IsServiceCenter) {
                                <span class="hub-active"><i class="fas fa-tools me-1"></i> Tech Hub</span>
                            }
                        </div>

                        <div class="mb-4">
                            <h4 class="fw-800 text-dark mb-1">@item.BusinessName</h4>
                            <div class="d-flex align-items-center gap-2 text-muted small fw-600">
                                <i class="fas fa-location-dot text-danger"></i> @item.Region Territory
                                <span class="text-light">|</span>
                                <i class="fas fa-user-tie"></i> @item.ContactPerson
                            </div>
                        </div>

                        <div class="metric-grid mb-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-800 uppercase">Annual Volume</span>
                                <span class="fw-800 text-dark fs-5">₹@item.AnnualTurnover.ToString("N0")</span>
                            </div>
                        </div>

                        <div class="neural-readout mb-4">
                            <div class="d-flex align-items-center gap-2 mb-2 text-white fw-bold" style="font-size: 0.7rem;">
                                <i class="fas fa-brain text-danger"></i> NEURAL INSIGHT
                            </div>
                            @EaproERP.Agents.AiEngine.RunDealerAgent(item)
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-dark rounded-pill px-4 fw-800 small uppercase shadow-sm">
                                View Portfolio
                            </a>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action-circle" title="Edit Profile"><i class="fas fa-pen-to-square"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action-circle text-danger" title="Revoke Status"><i class="fas fa-user-slash"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>