@model EaproERP.Models.Dealer
@{
    ViewData["Title"] = "Edit Dealer Profile";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Dealers" class="text-decoration-none text-muted">Dealer Network</a></li>
            <li class="breadcrumb-item active text-danger fw-bold" aria-current="page">Edit Profile</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="card border-0 shadow-lg" style="border-radius: 24px; overflow: hidden; background: #fff;">
                <div class="card-header border-0 p-4 d-flex align-items-center justify-content-between" 
                     style="background: linear-gradient(135deg, #0F111A 0%, #1c253b 100%); color: white;">
                    <div class="d-flex align-items-center">
                        <div class="bg-danger rounded-circle p-3 me-3 shadow-sm">
                            <i class="fas fa-user-edit fs-4"></i>
                        </div>
                        <div>
                            <h4 class="mb-0 fw-bold">Modify Partner Records</h4>
                            <small class="text-white-50">Editing: @Model.BusinessName</small>
                        </div>
                    </div>
                    <span class="badge bg-danger rounded-pill px-3">ID: #@Model.Id</span>
                </div>

                <div class="card-body p-5">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-12">
                                <h6 class="text-uppercase text-danger fw-bold small mb-3">Business Information</h6>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label fw-600 small text-muted">Entity Name</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-building text-muted"></i></span>
                                    <input asp-for="BusinessName" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="Enter business name" />
                                </div>
                                <span asp-validation-for="BusinessName" class="text-danger x-small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-600 small text-muted">Region / Territory</label>
                                <select asp-for="Region" class="form-select form-control-lg bg-light border-0 shadow-none">
                                    <option value="North">North India (Roorkee HQ)</option>
                                    <option value="South">South India</option>
                                    <option value="East">East India</option>
                                    <option value="West">West India</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-600 small text-muted">Primary Contact Person</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0"><i class="fas fa-user-tie text-muted"></i></span>
                                    <input asp-for="ContactPerson" class="form-control form-control-lg bg-light border-0 shadow-none" />
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-600 small text-muted">Dealer Tier Rank</label>
                                <select asp-for="Tier" class="form-select form-control-lg bg-light border-0 shadow-none">
                                    <option value="Silver">Silver Partner</option>
                                    <option value="Gold">Gold Partner</option>
                                    <option value="Platinum">Platinum (Elite)</option>
                                </select>
                            </div>

                            <div class="col-12 mt-4">
                                <h6 class="text-uppercase text-danger fw-bold small mb-3">Financials & Status</h6>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-600 small text-muted">Annual Turnover (₹)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 fw-bold">₹</span>
                                    <input asp-for="AnnualTurnover" class="form-control form-control-lg bg-light border-0 shadow-none" />
                                </div>
                            </div>

                            <div class="col-md-6 d-flex align-items-center">
                                <div class="form-check form-switch custom-switch mt-4 p-3 rounded-3 bg-light w-100">
                                    <input class="form-check-input ms-0" type="checkbox" asp-for="IsServiceCenter" id="serviceSwitch">
                                    <label class="form-check-label fw-600 ms-3" for="serviceSwitch">Authorized Service Hub</label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top d-flex gap-3">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm">
                                <i class="fas fa-save me-2"></i>Apply Changes
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                                Discard
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-600 { font-weight: 600; }
    .x-small { font-size: 0.75rem; }
    .form-control-lg, .form-select-lg { font-size: 1rem; padding: 12px 15px; }
    .input-group-text { border-radius: 12px 0 0 12px !important; }
    .form-control { border-radius: 0 12px 12px 0 !important; }
    .form-select { border-radius: 12px !important; }
    
    .custom-switch .form-check-input {
        width: 3em;
        height: 1.5em;
        cursor: pointer;
    }
    .custom-switch .form-check-input:checked {
        background-color: #10B981;
        border-color: #10B981;
    }
</style>