@model EaproERP.Models.Dealer
@{ 
    ViewData["Title"] = (Model?.Id > 0 ? "Update" : "Register") + " Partner"; 
}

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --eapro-bg: #F8FAFC;
    }

    .dealer-container { animation: slideInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* Premium Partner Header */
    .partner-header {
        background: linear-gradient(135deg, var(--eapro-slate) 0%, #0F172A 100%);
        border-radius: 30px;
        padding: 3rem;
        color: white;
        margin-bottom: -50px;
        position: relative;
        z-index: 2;
        border-right: 8px solid var(--eapro-red);
        box-shadow: 0 25px 50px rgba(0,0,0,0.15);
    }

    /* Main Form Card */
    .partner-card {
        background: white;
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
        padding: 6rem 4rem 4rem 4rem;
    }

    .section-divider {
        display: flex;
        align-items: center;
        gap: 15px;
        margin: 3rem 0 1.5rem 0;
    }
    .section-divider span {
        font-size: 0.75rem;
        font-weight: 800;
        color: #94A3B8;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .line { height: 1px; background: #f1f5f9; width: 100%; }

    .input-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 10px;
        display: block;
    }

    .form-control, .form-select {
        border-radius: 18px;
        background: #F1F5F9;
        border: 1px solid #E2E8F0;
        padding: 16px 20px;
        font-weight: 600;
        color: var(--eapro-slate);
        transition: 0.3s;
    }

    .form-control:focus {
        background: white;
        border-color: var(--eapro-red);
        box-shadow: 0 10px 25px rgba(211, 47, 47, 0.1);
        transform: translateY(-2px);
    }

    /* Premium Toggle Switch */
    .form-switch .form-check-input {
        width: 3rem;
        height: 1.5rem;
        cursor: pointer;
    }
    .form-switch .form-check-input:checked {
        background-color: var(--eapro-red);
        border-color: var(--eapro-red);
    }

    .btn-partner-save {
        background: var(--eapro-red);
        color: white;
        border: none;
        border-radius: 100px;
        padding: 18px 50px;
        font-weight: 800;
        letter-spacing: 1px;
        box-shadow: 0 15px 30px rgba(211, 47, 47, 0.2);
        transition: 0.4s;
    }

    .btn-partner-save:hover {
        background: #B91C1C;
        transform: scale(1.05);
        box-shadow: 0 20px 45px rgba(211, 47, 47, 0.3);
    }

    .tier-badge {
        padding: 10px 20px;
        border-radius: 15px;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
    }

    @@keyframes slideInUp { from { opacity: 0; transform: translateY(50px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container dealer-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="partner-header">
                <div class="row align-items-center">
                    <div class="col">
                        <span class="badge bg-danger bg-opacity-25 text-danger px-3 py-2 rounded-pill fw-800 mb-3">PARTNER NETWORK</span>
                        <h1 class="fw-800 mb-2">@(Model?.Id > 0 ? "Refine Partner Profile" : "Register New EAPRO Partner")</h1>
                        <div class="d-flex gap-3 mt-3">
                            <div class="tier-badge">
                                <i class="fas fa-handshake text-danger"></i>
                                <span class="small uppercase">EAPRO Verified</span>
                            </div>
                            @if(Model?.Tier != null) {
                                <div class="tier-badge">
                                    <i class="fas fa-crown text-warning"></i>
                                    <span class="small uppercase">@Model.Tier Status</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <i class="fas fa-network-wired text-white opacity-25" style="font-size: 7rem;"></i>
                    </div>
                </div>
            </div>

            <div class="partner-card">
                <form asp-action="@ViewContext.RouteData.Values["action"]">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 fw-bold"></div>
                    @if(Model?.Id > 0) { <input type="hidden" asp-for="Id" /> }

                    <div class="section-divider">
                        <span><i class="fas fa-id-card me-2"></i>Business Identity</span>
                        <div class="line"></div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-7">
                            <label class="input-label">Business Entity Name</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent text-muted"><i class="fas fa-building"></i></span>
                                <input asp-for="BusinessName" class="form-control ms-n3" placeholder="e.g. North Star Renewables" required />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <label class="input-label">Territory / Region</label>
                            <select asp-for="Region" class="form-select">
                                <option value="North">North India</option>
                                <option value="South">South India</option>
                                <option value="East">East India</option>
                                <option value="West">West India</option>
                            </select>
                        </div>
                    </div>

                    <div class="section-divider">
                        <span><i class="fas fa-user-tag me-2"></i>Classification & Contact</span>
                        <div class="line"></div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="input-label">Primary Contact Person</label>
                            <input asp-for="ContactPerson" class="form-control" placeholder="Full Name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Partner Tier Level</label>
                            <select asp-for="Tier" class="form-select">
                                <option value="Silver">Silver Partner</option>
                                <option value="Gold">Gold Partner</option>
                                <option value="Platinum">Platinum Executive Partner</option>
                            </select>
                        </div>
                    </div>

                    <div class="section-divider">
                        <span><i class="fas fa-chart-line me-2"></i>Growth & Infrastructure</span>
                        <div class="line"></div>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label class="input-label">Annual Turnover (INR)</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent fw-800 text-success">₹</span>
                                <input asp-for="AnnualTurnover" class="form-control ms-n3 fs-5 fw-800" placeholder="0.00" />
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="bg-light p-4 rounded-4 w-100 border d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-800 text-dark mb-0 small uppercase">Authorized Service Center</div>
                                    <div class="text-muted small">Capable of local technical support</div>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" asp-for="IsServiceCenter">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-top d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="text-decoration-none text-muted fw-800 small uppercase"><i class="fas fa-arrow-left me-2"></i>Back to Network</a>
                        <button type="submit" class="btn-partner-save">
                            FINALIZE PARTNERSHIP <i class="fas fa-check-circle ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>