@model IEnumerable<EaproERP.Models.Product>
@{
    ViewData["Title"] = "EAPRO Inventory Matrix";
    var totalValue = Model.Sum(x => x.Price * x.StockLevel);
}

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --glass-bg: rgba(255, 255, 255, 0.02);
        --neon-success: #00FF94;
    }

    .inventory-container { animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* --- 3D Metrics Header --- */
    .metric-card {
        background: white;
        border-radius: 28px;
        padding: 1.5rem;
        border: 1px solid #f1f5f9;
        box-shadow: 0 10px 25px rgba(0,0,0,0.03);
        transition: 0.3s;
        position: relative;
        overflow: hidden;
    }
    .metric-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
    .metric-icon { 
        width: 45px; height: 45px; border-radius: 12px; 
        display: flex; align-items: center; justify-content: center; 
        font-size: 1.2rem;
    }

    /* --- Premium Data Table --- */
    .matrix-card {
        background: white;
        border-radius: 35px;
        box-shadow: 0 40px 100px rgba(15, 23, 42, 0.08);
        border: 1px solid #f1f5f9;
        overflow: hidden;
    }

    .table-titan { margin-bottom: 0; }
    .table-titan thead th {
        background: #0F172A;
        color: #94A3B8;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1.5px;
        padding: 1.5rem;
        border: none;
    }

    .table-titan tbody tr { transition: 0.2s; border-bottom: 1px solid #f8fafc; }
    .table-titan tbody tr:hover { background: #fcfdfe; }
    .table-titan td { padding: 1.25rem 1.5rem; vertical-align: middle; border: none; }

    /* --- Stock Intelligence Visualization --- */
    .stock-bar-container { width: 100px; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
    .stock-bar { height: 100%; border-radius: 10px; }

    .ai-bubble {
        background: #0F172A;
        color: #94A3B8;
        padding: 12px 18px;
        border-radius: 18px;
        font-size: 0.8rem;
        font-family: 'JetBrains Mono', monospace;
        border-left: 4px solid var(--eapro-red);
        max-width: 280px;
        line-height: 1.4;
    }

    .price-tag { font-family: 'Outfit', sans-serif; font-weight: 800; color: #1e293b; font-size: 1.1rem; }

    /* --- Custom Control Buttons --- */
    .btn-matrix {
        width: 40px; height: 40px; border-radius: 12px;
        display: inline-flex; align-items: center; justify-content: center;
        background: #f8fafc; border: 1px solid #e2e8f0; color: #64748b;
        transition: 0.3s;
    }
    .btn-matrix:hover { transform: scale(1.1); background: var(--eapro-red); color: white; border-color: var(--eapro-red); }

    @@keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="inventory-container">
    <div class="row align-items-center mb-5 g-4">
        <div class="col-lg-6">
            <h1 class="fw-800 text-dark mb-1" style="letter-spacing: -2px;">Inventory <span class="text-danger">Matrix</span></h1>
            <p class="text-muted fw-600 mb-0"><i class="fas fa-microchip text-danger me-2"></i>Supply Chain Analytics • Roorkee Node S-04</p>
        </div>
        <div class="col-lg-6 text-lg-end">
            <a href="/Inventory/Create" class="btn btn-dark rounded-pill px-4 py-2 fw-800 shadow-lg border-0">
                <i class="fas fa-plus-circle me-2"></i>Initialize New SKU
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="metric-card d-flex align-items-center gap-3">
                <div class="metric-icon bg-danger bg-opacity-10 text-danger"><i class="fas fa-box-open"></i></div>
                <div>
                    <small class="text-muted fw-800 uppercase" style="font-size: 0.65rem;">Active SKUs</small>
                    <h4 class="fw-800 mb-0 text-dark">@Model.Count()</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card d-flex align-items-center gap-3">
                <div class="metric-icon bg-warning bg-opacity-10 text-warning"><i class="fas fa-triangle-exclamation"></i></div>
                <div>
                    <small class="text-muted fw-800 uppercase" style="font-size: 0.65rem;">Low Stock Alerts</small>
                    <h4 class="fw-800 mb-0 text-danger">@Model.Count(x => x.StockLevel < 10)</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card d-flex align-items-center gap-3">
                <div class="metric-icon bg-success bg-opacity-10 text-success"><i class="fas fa-indian-rupee-sign"></i></div>
                <div>
                    <small class="text-muted fw-800 uppercase" style="font-size: 0.65rem;">Inventory Valuation</small>
                    <h4 class="fw-800 mb-0 text-dark">₹@totalValue.ToString("N0")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card d-flex align-items-center gap-3">
                <div class="metric-icon bg-primary bg-opacity-10 text-primary"><i class="fas fa-robot"></i></div>
                <div>
                    <small class="text-muted fw-800 uppercase" style="font-size: 0.65rem;">Neural Status</small>
                    <h4 class="fw-800 mb-0 text-primary">Synchronized</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="matrix-card">
        <div class="table-responsive">
            <table class="table table-titan">
                <thead>
                    <tr>
                        <th class="ps-4">Product Hardware</th>
                        <th>Classification</th>
                        <th>Deployment Capacity</th>
                        <th>Valuation</th>
                        <th>Neural Stock Analysis</th>
                        <th class="text-end pe-4">Operations</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-800 text-dark fs-6">@item.Name</div>
                                <span class="badge bg-light text-muted border-0 fw-bold" style="font-size: 0.65rem;">REF: #EAP-@item.Id.ToString("D4")</span>
                            </td>
                            <td>
                                <span class="badge bg-dark rounded-pill px-3 py-2 fw-bold" style="font-size: 0.7rem;">@item.Category</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="stock-bar-container">
                                        <div class="stock-bar @(item.StockLevel < 10 ? "bg-danger" : "bg-success")" 
                                             style="width: @(Math.Min((item.StockLevel / 100.0) * 100, 100))%;"></div>
                                    </div>
                                    <span class="fw-800 @(item.StockLevel < 10 ? "text-danger" : "text-success")">@item.StockLevel Units</span>
                                </div>
                            </td>
                            <td>
                                <div class="price-tag">₹@item.Price.ToString("N0")</div>
                            </td>
                            <td>
                                <div class="ai-bubble shadow-sm">
                                    <i class="fas fa-brain text-danger me-2"></i> @item.AIStockPrediction
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Inventory/Details/@item.Id" class="btn-matrix" title="Full Dossier"><i class="fas fa-info-circle"></i></a>
                                    <a href="/Inventory/Edit/@item.Id" class="btn-matrix" title="Modify Specs"><i class="fas fa-sliders"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Archive SKU data?');">
                                        <button type="submit" class="btn-matrix text-danger"><i class="fas fa-trash-alt"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>