@model EaproERP.Models.Product
@{ 
    ViewData["Title"] = "Initialize SKU"; 
}

<style>
    :root {
        --eapro-red: #D32F2F;
        --eapro-slate: #1E293B;
        --input-bg: #F8FAFC;
    }

    .initialize-container { animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1); }

    /* --- Technical Header --- */
    .titan-header-card {
        background: linear-gradient(135deg, #0A0C12 0%, #1a1a1a 100%);
        border-radius: 30px;
        padding: 3rem;
        color: white;
        margin-bottom: -50px;
        position: relative;
        z-index: 2;
        border-left: 8px solid var(--eapro-red);
        box-shadow: 0 25px 50px rgba(0,0,0,0.3);
    }

    /* --- Form Architecture --- */
    .onboard-card {
        background: white;
        border-radius: 40px;
        box-shadow: 0 40px 100px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
        padding: 6rem 4rem 4rem 4rem;
    }

    .form-section-divider {
        display: flex;
        align-items: center;
        gap: 15px;
        margin: 2.5rem 0 1.5rem 0;
    }
    .form-section-divider span {
        font-size: 0.75rem;
        font-weight: 800;
        color: #94A3B8;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    .line { height: 1px; background: #f1f5f9; width: 100%; }

    .input-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #64748B;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 10px;
        display: block;
    }

    .form-control, .form-select {
        border-radius: 18px;
        background: var(--input-bg);
        border: 1px solid #E2E8F0;
        padding: 16px 20px;
        font-weight: 600;
        color: var(--eapro-slate);
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .form-control:focus {
        background: white;
        border-color: var(--eapro-red);
        box-shadow: 0 10px 25px rgba(211, 47, 47, 0.1);
        transform: translateY(-2px);
    }

    .price-input {
        font-size: 1.25rem;
        color: #10B981 !important;
        font-weight: 800;
    }

    .btn-save-sku {
        background: var(--eapro-red);
        color: white;
        border: none;
        border-radius: 100px;
        padding: 20px 50px;
        font-weight: 800;
        letter-spacing: 1px;
        box-shadow: 0 15px 35px rgba(211, 47, 47, 0.3);
        transition: 0.4s;
    }

    .btn-save-sku:hover {
        background: #B91C1C;
        transform: scale(1.05) translateY(-3px);
        box-shadow: 0 20px 45px rgba(211, 47, 47, 0.4);
    }

    .badge-id {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 10px 20px;
        border-radius: 15px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    @@keyframes slideUp { from { opacity: 0; transform: translateY(50px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="container initialize-container py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="titan-header-card">
                <div class="row align-items-center">
                    <div class="col">
                        <span class="badge bg-danger bg-opacity-25 text-danger px-3 py-2 rounded-pill fw-800 mb-3">INVENTORY ENGINE v5.0</span>
                        <h1 class="fw-800 mb-2">Initialize New <span class="text-danger">SKU</span></h1>
                        <div class="d-flex gap-4 mt-3">
                            <div class="badge-id">
                                <i class="fas fa-barcode text-danger"></i>
                                <span class="small fw-bold">AUTO_GEN_ACTIVE</span>
                            </div>
                            <div class="badge-id">
                                <i class="fas fa-microchip text-info"></i>
                                <span class="small fw-bold">DSP_PCU_READY</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <i class="fas fa-warehouse text-white opacity-10" style="font-size: 8rem;"></i>
                    </div>
                </div>
            </div>

            <div class="onboard-card">
                <form asp-action="Create" method="post">
                    
                    <div class="form-section-divider">
                        <span><i class="fas fa-tag me-2"></i>Product Identification</span>
                        <div class="line"></div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-8">
                            <label class="input-label">Official Product Name</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent text-muted"><i class="fas fa-cube"></i></span>
                                <input asp-for="Name" class="form-control ms-n3" placeholder="e.g. EAPRO Tron 3200 Hybrid PCU" required />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="input-label">Hardware Category</label>
                            <select asp-for="Category" class="form-select" required>
                                <option value="Inverter">Solar PCU / Inverter</option>
                                <option value="Battery">Energy Storage (Battery)</option>
                                <option value="Solar Panel">Photovoltaic Module</option>
                                <option value="Accessories">BOS Accessories</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-section-divider">
                        <span><i class="fas fa-chart-pie me-2"></i>Stock & Valuation Metrics</span>
                        <div class="line"></div>
                    </div>

                    <div class="row g-4 mb-5">
                        <div class="col-md-6">
                            <label class="input-label">Initial Deployment Stock</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent text-muted"><i class="fas fa-boxes-stacked"></i></span>
                                <input asp-for="StockLevel" type="number" class="form-control ms-n3 fw-bold" placeholder="0" required />
                            </div>
                            <small class="text-muted">Total units currently arriving at Roorkee Hub.</small>
                        </div>
                        <div class="col-md-6">
                            <label class="input-label">Unit List Price (INR)</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-transparent fw-800 text-success">₹</span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control ms-n3 price-input" placeholder="0.00" required />
                            </div>
                            <small class="text-muted">Standard market value per individual unit.</small>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-top d-flex justify-content-between align-items-center">
                        <a href="/Inventory" class="text-decoration-none text-muted fw-800 small uppercase">
                            <i class="fas fa-arrow-left me-2"></i>Abort Entry
                        </a>
                        <button type="submit" class="btn-save-sku shadow-lg">
                            SYNC TO NEURAL GRID <i class="fas fa-cloud-upload-alt ms-2"></i>
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>